  # Get the final result.
  #
  # @api private
  #
  # @return [ BulkWrite::Result ] The final result.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:87
  def result; end

  # @return [ Hash ] results The results hash.
  #
  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:29
  def results; end

  # @return [ Array<String> ] Deduplicated list of "host:port" addresses of
  #   the servers that produced the combined operation results.
  #
  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:33
  def server_addresses; end

  private

  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:93
  def combine_counts!(result); end

  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:112
  def combine_errors!(result); end

  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:101
  def combine_ids!(result); end

  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:127
  def combine_write_concern_errors!(result); end

  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:117
  def combine_write_errors!(result); end
end


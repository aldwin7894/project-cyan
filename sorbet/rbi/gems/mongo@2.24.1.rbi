  # @since 2.5.0
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/session.rb:1267
  def next_txn_num; end

  # @return [ BSON::Timestamp ] The latest seen operation time for this session.
  #
  # @since 2.5.0

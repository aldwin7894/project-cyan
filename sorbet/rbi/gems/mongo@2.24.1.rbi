  #
  # pkg:gem/mongo#lib/mongo/socket.rb:120
  def summary; end

  # @return [ Float ] timeout The socket timeout.
  #
  # pkg:gem/mongo#lib/mongo/socket.rb:85
  def timeout; end

  # Writes data to the socket instance.
  #

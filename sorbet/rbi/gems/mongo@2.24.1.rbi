# This is an implementation of a condition variable.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/condition_variable.rb:21
class Mongo::ConditionVariable
  extend ::Forwardable

  # pkg:gem/mongo#lib/mongo/condition_variable.rb:24
  def initialize(lock = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/condition_variable.rb:38
  def broadcast; end

  # pkg:gem/mongo#lib/mongo/condition_variable.rb:43
  def signal; end

  # pkg:gem/mongo#lib/mongo/condition_variable.rb:48
  def synchronize(*_arg0, **_arg1, &_arg2); end

  # Waits for the condition variable to be signaled up to timeout seconds.
  # If condition variable is not signaled, returns after timeout seconds.
  #
  # pkg:gem/mongo#lib/mongo/condition_variable.rb:31
  def wait(timeout = T.unsafe(nil)); end

  private

  # pkg:gem/mongo#lib/mongo/condition_variable.rb:52
  def raise_unless_locked!; end
end

# This module defines configuration options for Mongo.
#
# @api private
#

  # @param [ CommandSucceededEvent ] event The event.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/monitoring/command_log_subscriber.rb:74
  def succeeded(event); end

  private

  # pkg:gem/mongo#lib/mongo/monitoring/command_log_subscriber.rb:96
  def format_command(args); end

  # pkg:gem/mongo#lib/mongo/monitoring/command_log_subscriber.rb:102
  def prefix(event, connection_generation: T.unsafe(nil), connection_id: T.unsafe(nil), server_connection_id: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/monitoring/command_log_subscriber.rb:115
  def truncate(command); end

  # pkg:gem/mongo#lib/mongo/monitoring/command_log_subscriber.rb:119
  def truncating?; end
end


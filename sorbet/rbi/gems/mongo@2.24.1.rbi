  def single?(*_arg0, **_arg1, &_arg2); end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cluster.rb:352
  def srv_monitor; end

  # @note This method is experimental and subject to change.
  #
  # @api experimental
  # @since 2.7.0
  #
  # pkg:gem/mongo#lib/mongo/cluster.rb:475
  def summary; end

  # @return [ Object ] The cluster topology.

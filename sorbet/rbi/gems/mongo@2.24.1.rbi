  def sensitive; end

  # @return [ Integer ] server_connection_id The server connection id.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_started.rb:62
  def server_connection_id; end

  # @return [ nil | Object ] The service id, if any.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_started.rb:45
  def service_id; end

  # object_id of the socket object used for this command.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_started.rb:50
  def socket_object_id; end

  # Returns a concise yet useful summary of the event.

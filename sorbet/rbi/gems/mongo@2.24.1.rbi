# Shared behavior of operations that support a session.
#
# @since 2.5.2
# @api private
#
# pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:23
module Mongo::Operation::SessionsSupported
  private

  # Adds $readPreference field to the command document.
  #
  # $readPreference is only sent when the server is a mongos,
  # following the rules described in
  # https://github.com/mongodb/specifications/blob/master/source/server-selection/server-selection.md#passing-read-preference-to-mongos.
  # The topology does not matter for figuring out whether to send
  # $readPreference since the decision is always made based on
  # server type.
  #
  # $readPreference is sent to OP_MSG-grokking replica set members.
  #
  # @param [ Hash ] sel Existing command document which will be mutated.
  # @param [ Server::Connection ] connection The connection that the
  #   operation will be executed on.
  #
  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:161
  def add_read_preference(sel, connection); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:94
  def add_write_concern!(sel); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:98
  def apply_autocommit!(selector); end

  # Adds causal consistency document to the selector, if one can be
  # constructed and the selector is for a startTransaction command.
  #
  # When operations are performed in a transaction, only the first
  # operation (the one which starts the transaction via startTransaction)
  # is allowed to have a read concern, and with it the causal consistency
  # document, specified.
  #
  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:48
  def apply_causal_consistency!(selector, connection); end

  # Adds causal consistency document to the selector, if one can be
  # constructed.
  #
  # In order for the causal consistency document to be constructed,
  # causal consistency must be enabled for the session and the session
  # must have the current operation time. Also, topology must be
  # replica set or sharded cluster.
  #
  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:61
  def apply_causal_consistency_if_possible(selector, connection); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:77
  def apply_cluster_time!(selector, connection); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:110
  def apply_read_pref!(selector); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:207
  def apply_session_options(sel, connection); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:102
  def apply_start_transaction!(selector); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:106
  def apply_txn_num!(selector); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:114
  def apply_txn_opts!(selector); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:232
  def build_message(connection, context); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:126
  def command(connection); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:73
  def flags; end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:90
  def read_command?(sel); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:118
  def suppress_read_write_concern!(selector); end

  # pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:122
  def validate_read_preference!(selector); end
end

# pkg:gem/mongo#lib/mongo/operation/shared/sessions_supported.rb:28

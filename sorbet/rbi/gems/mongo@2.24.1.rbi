  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/cluster/topology/load_balanced.rb:35
  def summary; end

  # Returns whether this topology is Unknown.
  #
  # @return [ false ] Always false.
  #
  # pkg:gem/mongo#lib/mongo/cluster/topology/load_balanced.rb:95
  def unknown?; end

  private

  # pkg:gem/mongo#lib/mongo/cluster/topology/load_balanced.rb:101
  def validate_options(options, cluster); end
end


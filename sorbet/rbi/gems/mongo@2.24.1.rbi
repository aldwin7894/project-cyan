# Raised when an operation fails for some reason.
#
# pkg:gem/mongo#lib/mongo/error/operation_failure.rb:21
class Mongo::Error::OperationFailure < ::Mongo::Error
  include ::Mongo::Error::SdamErrorDetection
  include ::Mongo::Error::ReadWriteRetryable
  include ::Mongo::Error::OperationFailure::Family
end

# Implements the behavior for an OperationFailure error. Other errors
# (e.g. ServerTimeoutError) may also implement this, so that they may
# be recognized and treated as OperationFailure errors.
#
# pkg:gem/mongo#lib/mongo/error/operation_failure.rb:25
module Mongo::Error::OperationFailure::Family
  include ::Mongo::Error::SdamErrorDetection
  include ::Mongo::Error::ReadWriteRetryable
  extend ::Forwardable

  # Create the operation failure.
  #
  # @param [ String ] message The error message.
  # @param [ Operation::Result ] result The result object.
  # @param [ Hash ] options Additional parameters.
  #
  # @option options [ Integer ] :code Error code.
  # @option options [ String ] :code_name Error code name.
  # @option options [ BSON::Document ] :document The server-returned
  #   error document.
  # @option options [ String ] server_message The server-returned
  #   error message parsed from the response.
  # @option options [ nil | String | Mongo::Address | Mongo::Server::Description ]
  #   :server_address The address of the server that produced the error.
  # @option options [ Hash ] :write_concern_error_document The
  #   server-supplied write concern error document, if any.
  # @option options [ Integer ] :write_concern_error_code Error code for
  #   write concern error, if any.
  # @option options [ String ] :write_concern_error_code_name Error code
  #   name for write concern error, if any.
  # @option options [ Array<String> ] :write_concern_error_labels Error
  #   labels for the write concern error, if any.
  # @option options [ Array<String> ] :labels The set of labels associated
  #   with the error.
  # @option options [ true | false ] :wtimeout Whether the error is a wtimeout.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:192
  def initialize(message = T.unsafe(nil), result = T.unsafe(nil), options = T.unsafe(nil)); end

  # Can the change stream on which this error occurred be resumed,
  # provided the operation that triggered this error was a getMore?
  #
  # @example Is the error resumable for the change stream?
  #   error.change_stream_resumable?
  #
  # @return [ true, false ] Whether the error is resumable.
  #
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:100
  def change_stream_resumable?; end

  # @return [ Integer ] The error code parsed from the document.
  #
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:43
  def code; end

  # @return [ String ] The error code name parsed from the document.
  #
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:48
  def code_name; end

  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:38
  def connection_description(*_arg0, **_arg1, &_arg2); end

  # @return [ String | nil ] The details of the error.
  #   For WriteConcernErrors this is `document['writeConcernError']['errInfo']`.
  #   For WriteErrors this is `document['writeErrors'][0]['errInfo']`.
  #   For all other errors this is nil.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:155
  def details; end

  # @return [ BSON::Document | nil ] The server-returned error document.
  #
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:160
  def document; end

  # Whether the error is MaxTimeMSExpired.
  #
  # @return [ true | false ] Whether the error is MaxTimeMSExpired.
  #
  # @since 2.10.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:224
  def max_time_ms_expired?; end

  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:30
  def operation_time(*_arg0, **_arg1, &_arg2); end

  # @return [ Operation::Result ] the result object for the operation.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:165
  def result; end

  # @return [ String | nil ] The address ("host:port") of the server
  #   that produced this error, if known.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:58
  def server_address; end

  # @return [ String ] The server-returned error message
  #   parsed from the response.
  #
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:54
  def server_message; end

  # @return [ true | false ] Whether the failure includes a write
  #   concern error. A failure may have a top level error and a write
  #   concern error or either one of the two.
  #
  # @since 2.10.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:129
  def write_concern_error?; end

  # @return [ Integer | nil ] The error code for the write concern error,
  #   if a write concern error is present and has a code.
  #
  # @since 2.10.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:143
  def write_concern_error_code; end

  # @return [ String | nil ] The code name for the write concern error,
  #   if a write concern error is present and has a code name.
  #
  # @since 2.10.0
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:149
  def write_concern_error_code_name; end

  # Returns the write concern error document as it was reported by the
  # server, if any.
  #
  # @return [ Hash | nil ] Write concern error as reported to the server.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:137
  def write_concern_error_document; end

  # Whether the error is a write concern timeout.
  #
  # @return [ true | false ] Whether the error is a write concern timeout.
  #
  # @since 2.7.1
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:215
  def wtimeout?; end

  private

  # Append the details to the message
  #
  # @return [ String ] the message with the details appended to it
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:246
  def append_details(message, details); end

  # Append the server address suffix to the message when the
  # Mongo.include_server_address_in_errors flag is enabled and
  # a server address is known.
  #
  # @return [ String | nil ] the message with the suffix appended,
  #   or the original message unchanged.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:258
  def append_server_address(message); end

  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:119
  def change_stream_resumable_code?; end

  # Normalize a server_address option into a String "host:port" form.
  #
  # @param [ nil | String | Mongo::Address | Mongo::Server::Description ] value
  #
  # @return [ String | nil ] The normalized address, or nil.
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:271
  def normalize_server_address(value); end

  # Retrieve the details from a document
  #
  # @return [ Hash | nil ] the details extracted from the document
  #
  # pkg:gem/mongo#lib/mongo/error/operation_failure.rb:233
  def retrieve_details(document); end
end

# Error codes and code names that should result in a failing getMore
# command on a change stream NOT being resumed.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/error/operation_failure.rb:64
Mongo::Error::OperationFailure::Family::CHANGE_STREAM_RESUME_ERRORS = T.let(T.unsafe(nil), Array)

# Change stream can be resumed when these error messages are encountered.
#
# @since 2.6.0
# @api private
#
# pkg:gem/mongo#lib/mongo/error/operation_failure.rb:89
Mongo::Error::OperationFailure::Family::CHANGE_STREAM_RESUME_MESSAGES = T.let(T.unsafe(nil), Array)

# Class for parsing the various forms that errors can come in from MongoDB
# command responses.
#
# The errors can be reported by the server in a number of ways:
# - {ok:0} response indicates failure. In newer servers, code, codeName
#   and errmsg fields should be set. In older servers some may not be set.
# - {ok:1} response with a write concern error (writeConcernError top-level
#   field). This indicates that the node responding successfully executed
#   the request, but not enough other nodes successfully executed the
#   request to satisfy the write concern.
# - {ok:1} response with writeErrors top-level field. This can be obtained
#   in a bulk write but also in a non-bulk write. In a non-bulk write
#   there should be exactly one error in the writeErrors list.
#   The case of multiple errors is handled by BulkWrite::Result.
# - {ok:1} response with writeConcernErrors top-level field. This can
#   only be obtained in a bulk write and is handled by BulkWrite::Result,
#   not by this class.
#
# Note that writeErrors do not have codeName fields - they just provide
# codes and messages. writeConcernErrors may similarly not provide code
# names.
#
# @since 2.0.0
# @api private
#
# pkg:gem/mongo#lib/mongo/error/parser.rb:43
class Mongo::Error::Parser
  include ::Mongo::Error::SdamErrorDetection

  # Create the new parser with the returned document.
  #
  # @example Create the new parser.
  #   Parser.new({ 'errmsg' => 'failed' })
  #
  # @param [ BSON::Document ] document The returned document.
  # @param [ Array<Protocol::Message> ] replies The message replies.
  # @param [ Hash ] options The options.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:85
  def initialize(document, replies = T.unsafe(nil), options = T.unsafe(nil)); end

  # @return [ Integer ] The error code parsed from the document.
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:62
  def code; end

  # @return [ String ] The error code name parsed from the document.
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:66
  def code_name; end

  # @return [ BSON::Document ] The returned document.
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:47
  def document; end

  # @return [ Array<String> ] The set of labels associated with the error.
  # @since 2.7.0
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:70
  def labels; end

  # @return [ String ] The full error message to be used in the
  #   raised exception.
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:51
  def message; end

  # @return [ Array<Protocol::Message> ] The message replies.
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:58
  def replies; end

  # @return [ String ] The server-returned error message
  #   parsed from the response.
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:55
  def server_message; end

  # @return [ true | false ] Whether the document includes a write
  #   concern error. A failure may have a top level error and a write
  #   concern error or either one of the two.
  #
  # @since 2.10.0
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:102
  def write_concern_error?; end

  # @return [ Integer | nil ] The error code for the write concern error,
  #   if a write concern error is present and has a code.
  #
  # @since 2.10.0
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:120
  def write_concern_error_code; end

  # @return [ String | nil ] The code name for the write concern error,
  #   if a write concern error is present and has a code name.
  #
  # @since 2.10.0
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:129
  def write_concern_error_code_name; end

  # Returns the write concern error document as it was reported by the
  # server, if any.
  #
  # @return [ Hash | nil ] Write concern error as reported to the server.
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:111
  def write_concern_error_document; end

  # @return [ Array<String> | nil ] The error labels associated with this
  # write concern error, if there is a write concern error present.
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:135
  def write_concern_error_labels; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/error/parser.rb:73
  def wtimeout; end

  private

  # pkg:gem/mongo#lib/mongo/error/parser.rb:203
  def append(message, error); end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:158
  def parse!; end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:211
  def parse_code; end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:196
  def parse_flag(message); end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:241
  def parse_labels; end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:188
  def parse_multiple(message, key); end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:182
  def parse_single(message, key, doc = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/error/parser.rb:245
  def parse_wtimeout; end

  class << self
    # pkg:gem/mongo#lib/mongo/error/parser.rb:140
    def build_message(code: T.unsafe(nil), code_name: T.unsafe(nil), message: T.unsafe(nil)); end
  end
end


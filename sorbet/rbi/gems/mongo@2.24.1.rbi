# The symbol for opening a read stream.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/grid/stream.rb:32
Mongo::Grid::FSBucket::Stream::READ_MODE = T.let(T.unsafe(nil), Symbol)

# A stream that reads files from the FSBucket.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/grid/stream/read.rb:24
class Mongo::Grid::FSBucket::Stream::Read
  include ::Enumerable

  # Create a stream for reading files from the FSBucket.
  #
  # @example Create the stream.
  #   Stream::Read.new(fs, options)
  #
  # @param [ FSBucket ] fs The GridFS bucket object.
  # @param [ Hash ] options The read stream options.
  #
  # @option options [ BSON::Document ] :file_info_doc For internal
  #   driver use only. A BSON document to use as file information.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:54
  def initialize(fs, options); end

  # Close the read stream.
  #
  # If the stream is already closed, this method does nothing.
  #
  # @example Close the stream.
  #   stream.close
  #
  # @return [ BSON::ObjectId, Object ] The file id.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:127
  def close; end

  # Is the stream closed.
  #
  # @example Is the stream closed.
  #   stream.closed?
  #
  # @return [ true, false ] Whether the stream is closed.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:143
  def closed?; end

  # Iterate through chunk data streamed from the FSBucket.
  #
  # @example Iterate through the chunk data.
  #   stream.each do |data|
  #     buffer << data
  #   end
  #
  # @return [ Enumerator ] The enumerator.
  #
  # @raise [ Error::MissingFileChunk ] If a chunk is found out of sequence.
  #
  # @yieldparam [ Hash ] Each chunk of file data.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:82
  def each; end

  # @return [ BSON::ObjectId, Object ] file_id The id of the file being read.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:40
  def file_id; end

  # Get the files collection file information document for the file
  # being read.
  #
  # @note The file information is cached in the stream. Subsequent
  #   calls to file_info will return the same information that the
  #   first call returned, and will not query the database again.
  #
  # @return [ File::Info ] The file information object.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:181
  def file_info; end

  # @return [ FSBucket ] fs The fs bucket from which this stream reads.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:30
  def fs; end

  # @return [ Hash ] options The stream options.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:35
  def options; end

  # Read all file data.
  #
  # @example Read the file data.
  #   stream.read
  #
  # @return [ String ] The file data.
  #
  # @raise [ Error::MissingFileChunk ] If a chunk is found out of sequence.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:113
  def read; end

  # Get the read preference.
  #
  # @note This method always returns a BSON::Document instance, even
  #   though the constructor specifies the type of :read as a Hash, not
  #   as a BSON::Document.
  #
  # @return [ BSON::Document ] The read preference.
  #   The document may have the following fields:
  #   - *:mode* -- read preference specified as a symbol; valid values are
  #     *:primary*, *:primary_preferred*, *:secondary*, *:secondary_preferred*
  #     and *:nearest*.
  #   - *:tag_sets* -- an array of hashes.
  #   - *:local_threshold*.
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:160
  def read_preference; end

  private

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:198
  def ensure_file_info!; end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:194
  def ensure_open!; end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:202
  def ensure_readable!; end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:228
  def raise_unexpected_chunk_length!(chunk); end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:223
  def validate!(index, num_chunks, chunk, length_read); end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:233
  def validate_length!(index, num_chunks, chunk, length_read); end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:244
  def validate_n!(index, chunk); end

  # pkg:gem/mongo#lib/mongo/grid/stream/read.rb:207
  def view; end
end

# The symbol for opening a write stream.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/grid/stream.rb:37
Mongo::Grid::FSBucket::Stream::WRITE_MODE = T.let(T.unsafe(nil), Symbol)

# A stream that writes files to the FSBucket.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/grid/stream/write.rb:24
class Mongo::Grid::FSBucket::Stream::Write
  # Create a stream for writing files to the FSBucket.
  #
  # @example Create the stream.
  #   Stream::Write.new(fs, options)
  #
  # @param [ FSBucket ] fs The GridFS bucket object.
  # @param [ Hash ] options The write stream options.
  #
  # @option options [ Object ] :file_id The file id. An ObjectId
  #   is generated if the file id is not provided.
  # @option opts [ Integer ] :chunk_size Override the default chunk size.
  # @option opts [ Hash ] :metadata User data for the 'metadata' field of the files collection document.
  # @option opts [ String ] :content_type The content type of the file.
  #   Deprecated, please use the metadata document instead.
  # @option opts [ Array<String> ] :aliases A list of aliases.
  #   Deprecated, please use the metadata document instead.
  # @option options [ Hash ] :write Deprecated. Equivalent to :write_concern
  #   option.
  # @option options [ Hash ] :write_concern The write concern options.
  #   Can be :w => Integer|String, :fsync => Boolean, :j => Boolean.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:67
  def initialize(fs, options); end

  # Abort the upload by deleting all chunks already inserted.
  #
  # @example Abort the write operation.
  #   stream.abort
  #
  # @return [ true ] True if the operation was aborted and the stream is closed.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:178
  def abort; end

  # Close the write stream.
  #
  # @example Close the stream.
  #   stream.close
  #
  # @return [ BSON::ObjectId, Object ] The file id.
  #
  # @raise [ Error::ClosedStream ] If the stream is already closed.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:131
  def close; end

  # Is the stream closed.
  #
  # @example Is the stream closed.
  #   stream.closed?
  #
  # @return [ true, false ] Whether the stream is closed.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:166
  def closed?; end

  # @return [ Object ] file_id The id of the file being uploaded.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:33
  def file_id; end

  # @return [ String ] filename The name of the file being uploaded.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:38
  def filename; end

  # @return [ FSBucket ] fs The fs bucket to which this stream writes.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:28
  def fs; end

  # @return [ Hash ] options The write stream options.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:43
  def options; end

  # Write to the GridFS bucket from the source stream or a string.
  #
  # @example Write to GridFS.
  #   stream.write(io)
  #
  # @param [ String | IO ] io The string or IO object to upload from.
  #
  # @return [ Stream::Write ] self The write stream itself.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:100
  def write(io); end

  # Get the write concern used when uploading.
  #
  # @example Get the write concern.
  #   stream.write_concern
  #
  # @return [ Mongo::WriteConcern ] The write concern.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:150
  def write_concern; end

  private

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:188
  def chunks_collection; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:214
  def ensure_indexes!; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:218
  def ensure_open!; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:209
  def file_info; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:192
  def files_collection; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:205
  def update_length; end

  # pkg:gem/mongo#lib/mongo/grid/stream/write.rb:196
  def with_write_concern(collection); end
end

# A representation of a file in the database.
#
# @since 2.0.0
#
# @deprecated Please use the 'stream' API on a FSBucket instead.
#   Will be removed in driver version 3.0.
#
# pkg:gem/mongo#lib/mongo/grid/file/chunk.rb:19
class Mongo::Grid::File
  extend ::Forwardable

  # Initialize the file.
  #
  # @example Create the file.
  #   Grid::File.new(data, :filename => 'test.txt')
  #
  # @param [ IO, String, Array<BSON::Document> ] data The file object, file
  #   contents or chunks.
  # @param [ BSON::Document, Hash ] options The info options.
  #
  # @option options [ String ] :filename Required name of the file.
  # @option options [ String ] :content_type The content type of the file.
  #   Deprecated, please use the metadata document instead.
  # @option options [ String ] :metadata Optional file metadata.
  # @option options [ Integer ] :chunk_size Override the default chunk
  #   size.
  # @option opts [ Array<String> ] :aliases A list of aliases.
  #   Deprecated, please use the metadata document instead.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:75
  def initialize(data, options = T.unsafe(nil)); end

  # Check equality of files.
  #
  # @example Check the equality of files.
  #   file == other
  #
  # @param [ Object ] other The object to check against.
  #
  # @return [ true, false ] If the objects are equal.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:50
  def ==(other); end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def chunk_size(*_arg0, **_arg1, &_arg2); end

  # @return [ Array<Chunk> ] chunks The file chunks.
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:35
  def chunks; end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def content_type(*_arg0, **_arg1, &_arg2); end

  # Joins chunks into a string.
  #
  # @return [ String ] The raw data for the file.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:86
  def data; end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def filename(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def id(*_arg0, **_arg1, &_arg2); end

  # @return [ File::Info ] info The file information.
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:38
  def info; end

  # Gets a pretty inspection of the file.
  #
  # @example Get the file inspection.
  #   file.inspect
  #
  # @return [ String ] The file inspection.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/grid/file.rb:98
  def inspect; end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def md5(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/grid/file.rb:32
  def upload_date(*_arg0, **_arg1, &_arg2); end


  # pkg:gem/mongo#lib/mongo/socket.rb:76
  def family; end

  # Delegates gets to the underlying socket.
  #
  # @example Get the next line.
  #   socket.gets(10)
  #
  # @param [ Array<Object> ] args The arguments to pass through.

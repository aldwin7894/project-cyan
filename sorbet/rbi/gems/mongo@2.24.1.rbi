  def to_bson(buffer = T.unsafe(nil), _validating_keys = T.unsafe(nil)); end

  class << self
    # Takes an array of chunks and assembles them back into the full
    # piece of raw data.
    #
    # @example Assemble the chunks.
    #   Chunk.assemble(chunks)

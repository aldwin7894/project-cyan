# Event that is fired when a command operation fails.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:23
class Mongo::Monitoring::Event::CommandFailed < ::Mongo::Event::Base
  include ::Mongo::Monitoring::Event::Secure

  # Create the new event.
  #
  # @example Create the event.
  #
  # @param [ String ] command_name The name of the command.
  # @param [ String ] database_name The database_name name.
  # @param [ Server::Address ] address The server address.
  # @param [ Integer ] request_id The request id.
  # @param [ Integer ] operation_id The operation id.
  # @param [ String ] message The error message.
  # @param [ BSON::Document ] failure The error document, if any.
  # @param [ Float ] duration The duration the command took in seconds.
  # @param [ Monitoring::Event::CommandStarted ] started_event The corresponding
  #   started event.
  # @param [ Object ] service_id The service id, if any.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:83
  def initialize(command_name, database_name, address, request_id, operation_id, message, failure, duration, started_event:, server_connection_id: T.unsafe(nil), service_id: T.unsafe(nil)); end

  # @return [ Server::Address ] address The server address.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:27
  def address; end

  # @return [ String ] command_name The name of the command.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:30
  def command_name; end

  # @return [ String ] database_name The name of the database_name.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:33
  def database_name; end

  # @return [ Float ] duration The duration of the command in seconds.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:36
  def duration; end

  # @return [ BSON::Document ] failure The error document, if present.
  #   This will only be filled out for errors communicated by a
  #   MongoDB server. In other situations, for example in case of
  #   a network error, this attribute may be nil.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:42
  def failure; end

  # @return [ String ] message The error message. Unlike the error
  #   document, the error message should always be present.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:46
  def message; end

  # @return [ Integer ] operation_id The operation id.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:49
  def operation_id; end

  # @return [ Integer ] request_id The request id.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:52
  def request_id; end

  # @return [ Integer ] server_connection_id The server connection id.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:55
  def server_connection_id; end

  # @return [ nil | Object ] The service id, if any.
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:58
  def service_id; end

  # @return [ Monitoring::Event::CommandStarted ] started_event The corresponding
  #   started event.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:64
  def started_event; end

  # Returns a concise yet useful summary of the event.
  #
  # @return [ String ] String summary of the event.
  #
  # @note This method is experimental and subject to change.
  #
  # @api experimental
  #
  # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:106
  def summary; end

  class << self
    # Create the event from a wire protocol message payload.
    #
    # @example Create the event.
    #   CommandFailed.generate(address, 1, payload, duration)
    #
    # @param [ Server::Address ] address The server address.
    # @param [ Integer ] operation_id The operation id.
    # @param [ Hash ] payload The message payload.
    # @param [ String ] message The error message.
    # @param [ BSON::Document ] failure The error document, if any.
    # @param [ Float ] duration The duration of the command in seconds.
    # @param [ Monitoring::Event::CommandStarted ] started_event The corresponding
    #   started event.
    # @param [ Object ] service_id The service id, if any.
    #
    # @return [ CommandFailed ] The event.
    #
    # @since 2.1.0
    # @api private
    #
    # pkg:gem/mongo#lib/mongo/monitoring/event/command_failed.rb:129
    def generate(address, operation_id, payload, message, failure, duration, started_event:, server_connection_id: T.unsafe(nil), service_id: T.unsafe(nil)); end
  end
end


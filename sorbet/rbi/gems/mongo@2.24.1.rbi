# Defines iteration related behavior for collection views, including
# cursor instantiation.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:26
module Mongo::Collection::View::Iterable
  include ::Mongo::CursorHost

  # Cleans up resources associated with this query.
  #
  # If there is a server cursor associated with this query, it is
  # closed by sending a KillCursors command to the server.
  #
  # @note This method propagates any errors that occur when closing the
  #   server-side cursor.
  #
  # @return [ nil ] Always nil.
  #
  # @raise [ Error::OperationFailure::Family ] If the server cursor close fails.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:72
  def close_query; end

  # Iterate through documents returned by a query with this +View+.
  #
  # @example Iterate through the result of the view.
  #   view.each do |document|
  #     p document
  #   end
  #
  # @return [ Enumerator ] The enumerator.
  #
  # @since 2.0.0
  #
  # @yieldparam [ Hash ] Each matching document.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:41
  def each(&block); end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:77
  def kill_cursors; end

  private

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:114
  def cache_options; end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:110
  def cached_cursor; end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:216
  def compute_limit_for_cached_query; end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:130
  def initial_query_op(session); end

  # Add tailable cursor options to the command specification if needed.
  #
  # @param [ Hash ] spec The command specification.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:228
  def maybe_set_tailable_options(spec); end

  # Start a new cursor for use when iterating (via #each).
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:205
  def new_cursor_for_iteration; end

  # @return [ true | false | nil ] options[:oplog_replay], if
  #    set, otherwise the same option from the collection.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:240
  def oplog_replay; end

  # If the caching cursor is closed and was not fully iterated,
  # the documents we have in it are not the complete result set and
  # we have no way of completing that iteration.
  # Therefore, discard that cursor and start iteration again.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:198
  def prefer_cached_cursor?; end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:81
  def select_cursor(session); end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:172
  def send_initial_query(server, context, operation: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/iterable.rb:190
  def use_query_cache?; end
end

# Provides behavior around a map/reduce operation on the collection
# view.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:24
class Mongo::Collection::View::MapReduce
  include ::Enumerable
  include ::Mongo::Collection::View::Immutable
  include ::Mongo::Loggable
  include ::Mongo::Retryable
  extend ::Forwardable

  # Initialize the map/reduce for the provided collection view, functions
  # and options.
  #
  # @example Create the new map/reduce view.
  #
  # @param [ Collection::View ] view The collection view.
  # @param [ String ] map The map function.
  # @param [ String ] reduce The reduce function.
  # @param [ Hash ] options The map/reduce options.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:118
  def initialize(view, map, reduce, options = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:55
  def client(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:52
  def cluster(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:52
  def collection(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:55
  def database(*_arg0, **_arg1, &_arg2); end

  # Iterate through documents returned by the map/reduce.
  #
  # @example Iterate through the result of the map/reduce.
  #   map_reduce.each do |document|
  #     p document
  #   end
  #
  # @return [ Enumerator ] The enumerator.
  #
  # @since 2.0.0
  #
  # @yieldparam [ Hash ] Each matching document.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:69
  def each(&block); end

  # Execute the map reduce, without doing a fetch query to retrieve the results
  #   if outputted to a collection.
  #
  # @example Execute the map reduce and get the raw result.
  #   map_reduce.execute
  #
  # @return [ Mongo::Operation::Result ] The raw map reduce result
  #
  # @since 2.5.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:229
  def execute; end

  # Set or get the finalize function for the operation.
  #
  # @example Set the finalize function.
  #   map_reduce.finalize(function)
  #
  # @param [ String ] function The finalize js function.
  #
  # @return [ MapReduce, String ] The new MapReduce operation or the
  #   value of the function.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:103
  def finalize(function = T.unsafe(nil)); end

  # Set or get the jsMode flag for the operation.
  #
  # @example Set js mode for the operation.
  #   map_reduce.js_mode(true)
  #
  # @param [ true, false ] value The jsMode value.
  #
  # @return [ MapReduce, true, false ] The new MapReduce operation or the
  #   value of the jsMode flag.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:139
  def js_mode(value = T.unsafe(nil)); end

  # @return [ String ] map The map function.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:46
  def map_function; end

  # Set or get the output location for the operation.
  #
  # @example Set the output to inline.
  #   map_reduce.out(inline: 1)
  #
  # @example Set the output collection to merge.
  #   map_reduce.out(merge: 'users')
  #
  # @example Set the output collection to replace.
  #   map_reduce.out(replace: 'users')
  #
  # @example Set the output collection to reduce.
  #   map_reduce.out(reduce: 'users')
  #
  # @param [ Hash ] location The output location details.
  #
  # @return [ MapReduce, Hash ] The new MapReduce operation or the value
  #   of the output location.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:163
  def out(location = T.unsafe(nil)); end

  # Returns the collection name where the map-reduce result is written to.
  # If the result is returned inline, returns nil.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:169
  def out_collection_name; end

  # Returns the database name where the map-reduce result is written to.
  # If the result is returned inline, returns nil.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:179
  def out_database_name; end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:52
  def read(*_arg0, **_arg1, &_arg2); end

  # @return [ String ] reduce The reduce function.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:49
  def reduce_function; end

  # Set or get a scope on the operation.
  #
  # @example Set the scope value.
  #   map_reduce.scope(value: 'test')
  #
  # @param [ Hash ] object The scope object.
  #
  # @return [ MapReduce, Hash ] The new MapReduce operation or the value
  #   of the scope.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:200
  def scope(object = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:52
  def timeout_ms(*_arg0, **_arg1, &_arg2); end

  # Whether to include the timing information in the result.
  #
  # @example Set the verbose value.
  #   map_reduce.verbose(false)
  #
  # @param [ true, false ] value Whether to include timing information
  #   in the result.
  #
  # @return [ MapReduce, Hash ] The new MapReduce operation or the value
  #   of the verbose option.
  #
  # @since 2.0.5
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:216
  def verbose(value = T.unsafe(nil)); end

  # @return [ View ] view The collection view.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:43
  def view; end

  private

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:311
  def fetch_query_op(session); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:302
  def fetch_query_spec; end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:306
  def find_command_spec(session); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:259
  def initial_query_op(session); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:247
  def inline?; end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:251
  def map_reduce_spec(session = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:255
  def new(options); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:280
  def secondary_ok?; end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:324
  def send_fetch_query(server, session); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:328
  def send_fetch_query_with_connection(connection, session); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:284
  def send_initial_query(server, context); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:290
  def send_initial_query_with_connection(connection, session, context:); end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:243
  def server_selector; end

  # pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:276
  def valid_server?(description); end
end

# The inline option.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:34
Mongo::Collection::View::MapReduce::INLINE = T.let(T.unsafe(nil), String)

# pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:241
Mongo::Collection::View::MapReduce::OUT_ACTIONS = T.let(T.unsafe(nil), Array)

# Reroute message.
#
# @since 2.1.0
# @deprecated
#
# pkg:gem/mongo#lib/mongo/collection/view/map_reduce.rb:40
Mongo::Collection::View::MapReduce::REROUTE = T.let(T.unsafe(nil), String)

# Defines read related behavior for collection view.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/collection/view/readable.rb:23
module Mongo::Collection::View::Readable
  # Execute an aggregation on the collection view.
  #
  # @example Aggregate documents.
  #   view.aggregate([
  #     { "$group" => { "_id" => "$city", "tpop" => { "$sum" => "$pop" }}}
  #   ])
  #
  # @param [ Array<Hash> ] pipeline The aggregation pipeline.
  # @param [ Hash ] options The aggregation options.
  #
  # @option options [ true, false ] :allow_disk_use Set to true if disk
  #   usage is allowed during the aggregation.
  # @option options [ Integer ] :batch_size The number of documents to return
  #   per batch.
  # @option options [ true, false ] :bypass_document_validation Whether or
  #   not to skip document level validation.
  # @option options [ Hash ] :collation The collation to use.
  # @option options [ Object ] :comment A user-provided
  #   comment to attach to this command.
  # @option options [ String ] :hint The index to use for the aggregation.
  # @option options [ Hash ] :let Mapping of variables to use in the pipeline.
  #   See the server documentation for details.
  # @option options [ Integer ] :max_time_ms The maximum amount of time in
  #   milliseconds to allow the aggregation to run. This option is deprecated, use
  #   :timeout_ms instead.
  # @option options [ Session ] :session The session to use.
  # @option options [ Integer ] :timeout_ms The operation timeout in milliseconds.
  #    Must be a non-negative integer. An explicit value of 0 means infinite.
  #    The default value is unset which means the value is inherited from
  #    the collection or the database or the client.
  #
  # @return [ Aggregation ] The aggregation object.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:58
  def aggregate(pipeline, options = T.unsafe(nil)); end

  # Allows the server to write temporary data to disk while executing
  # a find operation.
  #
  # @return [ View ] The new view.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:77
  def allow_disk_use; end

  # Allows the query to get partial results if some shards are down.
  #
  # @example Allow partial results.
  #   view.allow_partial_results
  #
  # @return [ View ] The new view.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:89
  def allow_partial_results; end

  # Tell the query's cursor to stay open and wait for data.
  #
  # @example Await data on the cursor.
  #   view.await_data
  #
  # @return [ View ] The new view.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:101
  def await_data; end

  # The number of documents returned in each batch of results from MongoDB.
  #
  # @example Set the batch size.
  #   view.batch_size(5)
  #
  # @note Specifying 1 or a negative number is analogous to setting a limit.
  #
  # @param [ Integer ] batch_size The size of each batch of results.
  #
  # @return [ Integer, View ] Either the batch_size value or a
  #   new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:118
  def batch_size(batch_size = T.unsafe(nil)); end

  # Associate a comment with the query.
  #
  # @example Add a comment.
  #   view.comment('slow query')
  #
  # @note Set profilingLevel to 2 and the comment will be logged in the profile
  #   collection along with the query.
  #
  # @param [ Object ] comment The comment to be associated with the query.
  #
  # @return [ String, View ] Either the comment or a
  #   new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:136
  def comment(comment = T.unsafe(nil)); end

  # Get a count of matching documents in the collection.
  #
  # @example Get the number of documents in the collection.
  #   collection_view.count
  #
  # @param [ Hash ] opts Options for the operation.
  #
  # @option opts :skip [ Integer ] The number of documents to skip.
  # @option opts :hint [ Hash ] Override default index selection and force
  #   MongoDB to use a specific index for the query.
  # @option opts :limit [ Integer ] Max number of docs to count.
  # @option opts :max_time_ms [ Integer ] The maximum amount of time to allow the
  #   command to run.
  # @option opts [ Hash ] :read The read preference options.
  # @option opts [ Hash ] :collation The collation to use.
  # @option opts [ Mongo::Session ] :session The session to use for the operation.
  # @option opts [ Object ] :comment A user-provided
  #   comment to attach to this command.
  # @option options [ Integer ] :timeout_ms The operation timeout in milliseconds.
  #    Must be a non-negative integer. An explicit value of 0 means infinite.
  #    The default value is unset which means the value is inherited from
  #    the collection or the database or the client.
  #
  # @return [ Integer ] The document count.
  #
  # @since 2.0.0
  #
  # @deprecated Use #count_documents or #estimated_document_count instead. However, note that
  #   the following operators will need to be substituted when switching to #count_documents:
  #     * $where should be replaced with $expr
  #     * $near should be replaced with $geoWithin with $center
  #     * $nearSphere should be replaced with $geoWithin with $centerSphere
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:172
  def count(opts = T.unsafe(nil)); end

  # Get a count of matching documents in the collection.
  #
  # @example Get the number of documents in the collection.
  #   collection_view.count
  #
  # @param [ Hash ] opts Options for the operation.
  #
  # @option opts :skip [ Integer ] The number of documents to skip.
  # @option opts :hint [ Hash ] Override default index selection and force
  #   MongoDB to use a specific index for the query.
  # @option opts :limit [ Integer ] Max number of docs to count.
  # @option opts :max_time_ms [ Integer ] The maximum amount of time to allow the
  #   command to run. This option is deprecated, use
  #   :timeout_ms instead.
  # @option opts [ Hash ] :read The read preference options.
  # @option opts [ Hash ] :collation The collation to use.
  # @option opts [ Mongo::Session ] :session The session to use for the operation.
  # @option opts [ Object ] :comment A user-provided
  #   comment to attach to this command.
  # @option options [ Integer ] :timeout_ms The operation timeout in milliseconds.
  #    Must be a non-negative integer. An explicit value of 0 means infinite.
  #    The default value is unset which means the value is inherited from
  #    the collection or the database or the client.
  #
  # @return [ Integer ] The document count.
  #
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:242
  def count_documents(opts = T.unsafe(nil)); end

  # The type of cursor to use. Can be :tailable or :tailable_await.
  #
  # @example Set the cursor type.
  #   view.cursor_type(:tailable)
  #
  # @param [ :tailable, :tailable_await ] type The cursor type.
  #
  # @return [ :tailable, :tailable_await, View ] Either the cursor type setting or a new +View+.
  #
  # @since 2.3.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:665
  def cursor_type(type = T.unsafe(nil)); end

  # Get a list of distinct values for a specific field.
  #
  # @example Get the distinct values.
  #   collection_view.distinct('name')
  #
  # @param [ String, Symbol ] field_name The name of the field.
  # @param [ Hash ] opts Options for the distinct command.
  #
  # @option opts :max_time_ms [ Integer ] The maximum amount of time to allow the
  #   command to run.
  # @option opts [ Hash ] :read The read preference options.
  # @option opts [ Hash ] :collation The collation to use.
  # @option options [ Object ] :comment A user-provided
  #   comment to attach to this command.
  #
  # @return [ Array<Object> ] The list of distinct values.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:344
  def distinct(field_name, opts = T.unsafe(nil)); end

  # Gets an estimate of the count of documents in a collection using collection metadata.
  #
  # @example Get the number of documents in the collection.
  #   collection_view.estimated_document_count
  #
  # @param [ Hash ] opts Options for the operation.
  #
  # @option opts :max_time_ms [ Integer ] The maximum amount of time to allow the command to
  #   run.
  # @option opts [ Hash ] :read The read preference options.
  # @option opts [ Object ] :comment A user-provided
  #   comment to attach to this command.
  # @option options [ Integer ] :timeout_ms The operation timeout in milliseconds.
  #    Must be a non-negative integer. An explicit value of 0 means infinite.
  #    The default value is unset which means the value is inherited from
  #    the collection or the database or the client.
  #
  # @return [ Integer ] The document count.
  #
  # @since 2.6.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:278
  def estimated_document_count(opts = T.unsafe(nil)); end

  # The index that MongoDB will be forced to use for the query.
  #
  # @example Set the index hint.
  #   view.hint(name: 1)
  #
  # @param [ Hash ] hint The index to use for the query.
  #
  # @return [ Hash, View ] Either the hint or a new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:398
  def hint(hint = T.unsafe(nil)); end

  # The max number of docs to return from the query.
  #
  # @example Set the limit.
  #   view.limit(5)
  #
  # @param [ Integer ] limit The number of docs to return.
  #
  # @return [ Integer, View ] Either the limit or a new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:412
  def limit(limit = T.unsafe(nil)); end

  # Execute a map/reduce operation on the collection view.
  #
  # @example Execute a map/reduce.
  #   view.map_reduce(map, reduce)
  #
  # @param [ String ] map The map js function.
  # @param [ String ] reduce The reduce js function.
  # @param [ Hash ] options The map/reduce options.
  #
  # @return [ MapReduce ] The map reduce wrapper.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:428
  def map_reduce(map, reduce, options = T.unsafe(nil)); end

  # A cumulative time limit in milliseconds for processing get more operations
  # on a cursor.
  #
  # @example Set the max await time ms value.
  #   view.max_await_time_ms(500)
  #
  # @param [ Integer ] max The max time in milliseconds.
  #
  # @return [ Integer, View ] Either the max await time ms value or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:637
  def max_await_time_ms(max = T.unsafe(nil)); end

  # Set the max number of documents to scan.
  #
  # @example Set the max scan value.
  #   view.max_scan(1000)
  #
  # @param [ Integer ] value The max number to scan.
  #
  # @return [ Integer, View ] The value or a new +View+.
  #
  # @since 2.0.0
  #
  # @deprecated This option is deprecated as of MongoDB server
  #   version 4.0.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:445
  def max_scan(value = T.unsafe(nil)); end

  # A cumulative time limit in milliseconds for processing operations on a cursor.
  #
  # @example Set the max time ms value.
  #   view.max_time_ms(500)
  #
  # @param [ Integer ] max The max time in milliseconds.
  #
  # @return [ Integer, View ] Either the max time ms value or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:651
  def max_time_ms(max = T.unsafe(nil)); end

  # Set the maximum value to search.
  #
  # @example Set the max value.
  #   view.max_value(_id: 1)
  #
  # @param [ Hash ] value The max field and value.
  #
  # @return [ Hash, View ] The value or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:459
  def max_value(value = T.unsafe(nil)); end

  # Set the minimum value to search.
  #
  # @example Set the min value.
  #   view.min_value(_id: 1)
  #
  # @param [ Hash ] value The min field and value.
  #
  # @return [ Hash, View ] The value or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:473
  def min_value(value = T.unsafe(nil)); end

  # If called without arguments or with a nil argument, returns
  # the legacy (OP_QUERY) server modifiers for the current view.
  # If called with a non-nil argument, which must be a Hash or a
  # subclass, merges the provided modifiers into the current view.
  # Both string and symbol keys are allowed in the input hash.
  #
  # @example Set the modifiers document.
  #   view.modifiers(:$orderby => Mongo::Index::ASCENDING)
  #
  # @param [ Hash ] doc The modifiers document.
  #
  # @return [ Hash, View ] Either the modifiers document or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:618
  def modifiers(doc = T.unsafe(nil)); end

  # The server normally times out idle cursors after an inactivity period
  # (10 minutes) to prevent excess memory use. Set this option to prevent that.
  #
  # @example Set the cursor to not timeout.
  #   view.no_cursor_timeout
  #
  # @return [ View ] The new view.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:486
  def no_cursor_timeout; end

  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:707
  def parallel_scan(cursor_count, options = T.unsafe(nil)); end

  # The fields to include or exclude from each doc in the result set.
  #
  # @example Set the fields to include or exclude.
  #   view.projection(name: 1)
  #
  # @note A value of 0 excludes a field from the doc. A value of 1 includes it.
  #   Values must all be 0 or all be 1, with the exception of the _id value.
  #   The _id field is included by default. It must be excluded explicitly.
  #
  # @param [ Hash ] document The field and 1 or 0, to include or exclude it.
  #
  # @return [ Hash, View ] Either the fields or a new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:504
  def projection(document = T.unsafe(nil)); end

  # The read preference to use for the query.
  #
  # @note If none is specified for the query, the read preference of the
  #   collection will be used.
  #
  # @param [ Hash ] value The read preference mode to use for the query.
  #
  # @return [ Symbol, View ] Either the read preference or a
  #   new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:520
  def read(value = T.unsafe(nil)); end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:679
  def read_concern; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:688
  def read_preference; end

  # Set whether to return only the indexed field or fields.
  #
  # @example Set the return key value.
  #   view.return_key(true)
  #
  # @param [ true, false ] value The return key value.
  #
  # @return [ true, false, View ] The value or a new +View+.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:536
  def return_key(value = T.unsafe(nil)); end

  # Set whether the disk location should be shown for each document.
  #
  # @example Set show disk location option.
  #   view.show_disk_loc(true)
  #
  # @param [ true, false ] value The value for the field.
  #
  # @return [ true, false, View ] Either the value or a new
  #   +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:551
  def show_disk_loc(value = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:554
  def show_record_id(value = T.unsafe(nil)); end

  # The number of docs to skip before returning results.
  #
  # @example Set the number to skip.
  #   view.skip(10)
  #
  # @param [ Integer ] number Number of docs to skip.
  #
  # @return [ Integer, View ] Either the skip value or a
  #   new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:567
  def skip(number = T.unsafe(nil)); end

  # Set the snapshot value for the view.
  #
  # @note When set to true, prevents documents from returning more than
  #   once.
  #
  # @example Set the snapshot value.
  #   view.snapshot(true)
  #
  # @param [ true, false ] value The snapshot value.
  #
  # @since 2.0.0
  #
  # @deprecated This option is deprecated as of MongoDB server
  #   version 4.0.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:585
  def snapshot(value = T.unsafe(nil)); end

  # The key and direction pairs by which the result set will be sorted.
  #
  # @example Set the sort criteria
  #   view.sort(name: -1)
  #
  # @param [ Hash ] spec The attributes and directions to sort by.
  #
  # @return [ Hash, View ] Either the sort setting or a
  #   new +View+.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:600
  def sort(spec = T.unsafe(nil)); end

  # The per-operation timeout in milliseconds. Must a positive integer.
  #
  # @param [ Integer ] timeout_ms Timeout value.
  #
  # @return [ Integer, View ] Either the timeout_ms value or a new +View+.
  #
  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:674
  def timeout_ms(timeout_ms = T.unsafe(nil)); end

  private

  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:754
  def collation(doc = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:758
  def server_selector; end

  # pkg:gem/mongo#lib/mongo/collection/view/readable.rb:766
  def validate_doc!(doc); end
end

# Defines write related behavior for collection view.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/collection/view/writable.rb:23
module Mongo::Collection::View::Writable
  # Remove documents from the collection.
  #
  # @example Remove multiple documents from the collection.
  #   collection_view.delete_many
  #
  # @param [ Hash ] opts The options.
  #
  # @option opts [ Hash ] :collation The collation to use.
  # @option opts [ Session ] :session The session to use.
  # @option options [ Integer ] :timeout_ms The operation timeout in milliseconds.
  #    Must be a non-negative integer. An explicit value of 0 means infinite.
  #    The default value is unset which means the value is inherited from
  #    the collection or the database or the client.
  # @option opts [ Hash | String ] :hint The index to use for this operation.
  #   May be specified as a Hash (e.g. { _id: 1 }) or a String (e.g. "_id_").
  # @option opts [ Hash ] :write_concern The write concern options.
  #   Can be :w => Integer, :fsync => Boolean, :j => Boolean.
  # @option opts [ Hash ] :let Mapping of variables to use in the command.
  #   See the server documentation for details.
  # @option opts [ Object ] :comment A user-provided
  #   comment to attach to this command.
  #
  # @return [ Result ] The response from the database.
  #
  # @since 2.0.0
  #

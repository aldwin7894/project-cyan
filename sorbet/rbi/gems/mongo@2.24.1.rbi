# This module caches OCSP responses for their indicated validity time.
#
# The key is the CertificateId used for the OCSP request.
# The value is an OcspVerifier::Response.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:25
module Mongo::Socket::OcspCache
  private

  # Clears the driver's OCSP response cache.
  #
  # @note Use Mongo.clear_ocsp_cache from applications instead of invoking
  #   this method directly.
  #
  # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:79
  def clear; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:69
  def delete(cert_id); end

  # Retrieves a cached SingleResponse for the specified CertificateId.
  #
  # This method may return expired responses if they are revoked.
  # Such responses were valid when they were first received.
  #
  # This method may also return responses that are valid but that may
  # expire by the time caller uses them. The caller should not perform
  # update time checks on the returned response.
  #
  # @return [ OpenSSL::OCSP::SingleResponse ] The previously
  #   retrieved response.
  #
  # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:42
  def get(cert_id); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:87
  def responses; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:26
  def set(cert_id, response); end

  class << self
    # Clears the driver's OCSP response cache.
    #
    # @note Use Mongo.clear_ocsp_cache from applications instead of invoking
    #   this method directly.
    #
    # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:79
    def clear; end

    # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:69
    def delete(cert_id); end

    # Retrieves a cached SingleResponse for the specified CertificateId.
    #
    # This method may return expired responses if they are revoked.
    # Such responses were valid when they were first received.
    #
    # This method may also return responses that are valid but that may
    # expire by the time caller uses them. The caller should not perform
    # update time checks on the returned response.
    #
    # @return [ OpenSSL::OCSP::SingleResponse ] The previously
    #   retrieved response.
    #
    # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:42
    def get(cert_id); end

    # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:87
    def responses; end

    # pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:26
    def set(cert_id, response); end
  end
end

# pkg:gem/mongo#lib/mongo/socket/ocsp_cache.rb:85
Mongo::Socket::OcspCache::LOCK = T.let(T.unsafe(nil), Thread::Mutex)

# OCSP endpoint verifier.
#
# After a TLS connection is established, this verifier inspects the
# certificate presented by the server, and if the certificate contains
# an OCSP URI, performs the OCSP status request to the specified URI
# (following up to 5 redirects) to verify the certificate status.
#
# @see https://ruby-doc.org/stdlib/libdoc/openssl/rdoc/OpenSSL/OCSP.html
#
# @api private
#
# pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:35
class Mongo::Socket::OcspVerifier
  include ::Mongo::Loggable

  # @param [ String ] host_name The host name being verified, for
  #   diagnostic output.
  # @param [ OpenSSL::X509::Certificate ] cert The certificate presented by
  #   the server at host_name.
  # @param [ OpenSSL::X509::Certificate ] ca_cert The CA certificate
  #   presented by the server or resolved locally from the server
  #   certificate.
  # @param [ OpenSSL::X509::Store ] cert_store The certificate store to
  #   use for verifying OCSP response. This should be the same store as
  #   used in SSLContext used with the SSLSocket that we are verifying the
  #   certificate for. This must NOT be the CA certificate provided by
  #   the server (i.e. anything taken out of peer_cert) - otherwise the
  #   server would dictate which CA authorities the client trusts.
  #
  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:64
  def initialize(host_name, cert, ca_cert, cert_store, **opts); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:72
  def ca_cert; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:72
  def cert; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:100
  def cert_id; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:72
  def cert_store; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:72
  def host_name; end

  # @return [ Array<String> ] OCSP URIs in the specified server certificate.
  #
  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:79
  def ocsp_uris; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:72
  def options; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:74
  def timeout; end

  # @return [ true | false ] Whether the certificate was verified.
  #
  # @raise [ Error::ServerCertificateRevoked ] If the certificate was
  #   definitively revoked.
  #
  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:127
  def verify; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:108
  def verify_with_cache; end

  private

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:138
  def do_verify; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:303
  def handle_exceptions; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:316
  def raise_revoked_error(resp); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:334
  def report_response_body(body); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:326
  def report_uri(original_uri, uri); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:284
  def return_ocsp_response(resp, errors = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:180
  def verify_one_responder(uri); end
end

# Wraps OpenSSL::OCSP::SingleResponse with the responder URI that supplied it.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:39
class Mongo::Socket::OcspVerifier::Response < ::SimpleDelegator
  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:42
  def initialize(single_response, uri, original_uri); end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:40
  def original_uri; end

  # pkg:gem/mongo#lib/mongo/socket/ocsp_verifier.rb:40
  def uri; end
end

# Wrapper for TLS sockets.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/socket/ssl.rb:22
class Mongo::Socket::SSL < ::Mongo::Socket
  include ::OpenSSL
  include ::Mongo::Loggable

  # Initializes a new TLS socket.
  #
  # @example Create the TLS socket.
  #   SSL.new('::1', 27017, 30)
  #
  # @param [ String ] host The hostname or IP address.
  # @param [ Integer ] port The port number.
  # @param [ Float ] timeout The socket timeout value.
  # @param [ Integer ] family The socket family.
  # @param [ Hash ] options The options.
  #
  # @option options [ Float ] :connect_timeout Connect timeout.
  # @option options [ Address ] :connection_address Address of the
  #   connection that created this socket.
  # @option options [ Integer ] :connection_generation Generation of the
  #   connection (for non-monitoring connections) that created this socket.
  # @option options [ true | false ] :monitor Whether this socket was
  #   created by a monitoring connection.
  # @option options [ String ] :ssl_ca_cert The file containing concatenated
  #   certificate authority certificates used to validate certs passed from the
  #   other end of the connection. Intermediate certificates should NOT be
  #   specified in files referenced by this option. One of :ssl_ca_cert,
  #   :ssl_ca_cert_string or :ssl_ca_cert_object (in order of priority) is
  #   required when using :ssl_verify.
  # @option options [ Array<OpenSSL::X509::Certificate> ] :ssl_ca_cert_object
  #   An array of OpenSSL::X509::Certificate objects representing the
  #   certificate authority certificates used to validate certs passed from
  #   the other end of the connection. Intermediate certificates should NOT
  #   be specified in files referenced by this option. One of :ssl_ca_cert,
  #   :ssl_ca_cert_string or :ssl_ca_cert_object (in order of priority)
  #   is required when using :ssl_verify.
  # @option options [ String ] :ssl_ca_cert_string A string containing
  #   certificate authority certificate used to validate certs passed from the
  #   other end of the connection. This option allows passing only one CA
  #   certificate to the driver. Intermediate certificates should NOT
  #   be specified in files referenced by this option. One of :ssl_ca_cert,
  #   :ssl_ca_cert_string or :ssl_ca_cert_object (in order of priority) is
  #   required when using :ssl_verify.
  # @option options [ String ] :ssl_cert The certificate file used to identify
  #   the connection against MongoDB. A certificate chain may be passed by
  #   specifying the client certificate first followed by any intermediate
  #   certificates up to the CA certificate. The file may also contain the
  #   certificate's private key, which will be ignored. This option, if present,
  #   takes precedence over the values of :ssl_cert_string and :ssl_cert_object
  # @option options [ OpenSSL::X509::Certificate ] :ssl_cert_object The OpenSSL::X509::Certificate
  #   used to identify the connection against MongoDB. Only one certificate
  #   may be passed through this option.
  # @option options [ String ] :ssl_cert_string A string containing the PEM-encoded
  #   certificate used to identify the connection against MongoDB. A certificate
  #   chain may be passed by specifying the client certificate first followed
  #   by any intermediate certificates up to the CA certificate. The string
  #   may also contain the certificate's private key, which will be ignored,
  #   This option, if present, takes precedence over the value of :ssl_cert_object
  # @option options [ String ] :ssl_key The private keyfile used to identify the
  #   connection against MongoDB. Note that even if the key is stored in the same
  #   file as the certificate, both need to be explicitly specified. This option,
  #   if present, takes precedence over the values of :ssl_key_string and :ssl_key_object
  # @option options [ OpenSSL::PKey ] :ssl_key_object The private key used to identify the
  #   connection against MongoDB
  # @option options [ String ] :ssl_key_pass_phrase A passphrase for the private key.
  # @option options [ String ] :ssl_key_string A string containing the PEM-encoded private key
  #   used to identify the connection against MongoDB. This parameter, if present,
  #   takes precedence over the value of option :ssl_key_object
  # @option options [ true, false ] :ssl_verify Whether to perform peer certificate validation and
  #   hostname verification. Note that the decision of whether to validate certificates will be
  #   overridden if :ssl_verify_certificate is set, and the decision of whether to validate
  #   hostnames will be overridden if :ssl_verify_hostname is set.
  # @option options [ true, false ] :ssl_verify_certificate Whether to perform peer certificate
  #   validation. This setting overrides :ssl_verify with respect to whether certificate
  #   validation is performed.
  # @option options [ true, false ] :ssl_verify_hostname Whether to perform peer hostname
  #   validation. This setting overrides :ssl_verify with respect to whether hostname validation
  #   is performed.
  #
  # @since 2.0.0
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:102
  def initialize(host, port, host_name, timeout, family, options = T.unsafe(nil)); end

  # @return [ SSLContext ] context The TLS context.
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:121
  def context; end

  # @return [ String ] host The host to connect to.
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:124
  def host; end

  # @return [ String ] host_name The original host name.
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:127
  def host_name; end

  # @return [ Integer ] port The port to connect to.
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:130
  def port; end

  # Read a single byte from the socket.
  #
  # @example Read a single byte.
  #   socket.readbyte
  #
  # @return [ Object ] The read byte.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:187
  def readbyte; end

  private

  # Establishes a socket connection.
  #
  # @example Connect the socket.
  #   sock.connect!
  #
  # @note This method mutates the object by setting the socket
  #   internally.
  #
  # @return [ SSL ] The connected socket instance.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:143
  def connect!; end

  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:221
  def connect_tcp_socket_with_timeout(sockaddr, deadline, connect_timeout); end

  # Connects the socket with the connect timeout. The timeout applies to
  # connecting both ssl socket and the underlying tcp socket.
  #
  # @param [ String ] sockaddr Address to connect to.
  #
  # pkg:gem/mongo#lib/mongo/socket/ssl.rb:211
  def connect_with_timeout(sockaddr, connect_timeout); end

  # Connects the socket without a timeout provided.
  #
  # @param [ String ] sockaddr Address to connect to.

  #   message.payload
  #
  # @return [ BSON::Document ] The event payload.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/protocol/reply.rb:61
  def payload; end

  # Determine if the reply had a query failure flag.
  #
  # @example Did the reply have a query failure.
  #   reply.query_failure?
  #
  # @return [ true, false ] If the query failed.
  #
  # @since 2.0.5
  #
  # pkg:gem/mongo#lib/mongo/protocol/reply.rb:37
  def query_failure?; end

  # pkg:gem/mongo#lib/mongo/protocol/reply.rb:102
  def starting_from; end

  private

  # pkg:gem/mongo#lib/mongo/protocol/reply.rb:70
  def upconverter; end
end


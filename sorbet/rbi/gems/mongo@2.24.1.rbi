# Azure access token for temporary credentials.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/crypt/kms/azure/access_token.rb:24
class Mongo::Crypt::KMS::Azure::AccessToken
  # Creates an Azure access token object.
  #
  # @param [ String ] access_token Azure access token.
  # @param [ Integer ] expires_in Azure access token expiration time.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms/azure/access_token.rb:35
  def initialize(access_token, expires_in); end

  # @return [ String ] Azure access token.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms/azure/access_token.rb:26
  def access_token; end

  # Checks if the access token is expired.
  #
  # The access token is considered expired if it is within 60 seconds
  # of its expiration time.
  #
  # @return [ true | false ] Whether the access token is expired.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms/azure/access_token.rb:47
  def expired?; end

  # @return [ Integer ] Azure access token expiration time.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms/azure/access_token.rb:29
  def expires_in; end
end


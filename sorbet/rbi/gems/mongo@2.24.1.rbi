  # pkg:gem/mongo#lib/mongo/config.rb:35
  def include_server_address_in_errors=(value); end

  # pkg:gem/mongo#lib/mongo/config.rb:35
  def include_server_address_in_errors?; end

  # Set the configuration options.
  #
  # @example Set the options.
  #   config.options = { validate_update_replace: true }
  #
  # @param [ Hash ] options The configuration options.
  #
  # pkg:gem/mongo#lib/mongo/config.rb:43

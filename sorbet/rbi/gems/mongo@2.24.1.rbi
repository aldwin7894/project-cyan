# @api private
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:24
class Mongo::BulkWrite::ResultCombiner
  # Create the new result combiner.
  #
  # @api private
  #
  # @example Create the result combiner.
  #   ResultCombiner.new
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/bulk_write/result_combiner.rb:43

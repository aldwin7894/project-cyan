  # pkg:gem/mongo#lib/mongo/auth/credential_cache.rb:29
  def get(key); end

  # pkg:gem/mongo#lib/mongo/auth/credential_cache.rb:36
  def set(key, value); end

  class << self
    # pkg:gem/mongo#lib/mongo/auth/credential_cache.rb:43
    def cache(key); end

    # pkg:gem/mongo#lib/mongo/auth/credential_cache.rb:52
    def clear; end

    # pkg:gem/mongo#lib/mongo/auth/credential_cache.rb:29

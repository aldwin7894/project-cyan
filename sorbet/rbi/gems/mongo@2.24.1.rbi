  # pkg:gem/mongo#lib/mongo/server/connection_base.rb:83
  def mongos?(*_arg0, **_arg1, &_arg2); end

  # @return [ Hash ] options The passed in options.
  #
  # pkg:gem/mongo#lib/mongo/server/connection_base.rb:51
  def options; end

  # @return [ Server ] The server that this connection is for.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/server/connection_base.rb:56
  def server; end

  # @return [ nil | Object ] The service id, if any.
  #
  # pkg:gem/mongo#lib/mongo/server/connection_base.rb:90
  def service_id; end

  # pkg:gem/mongo#lib/mongo/server/connection_base.rb:62
  def update_cluster_time(*_arg0, **_arg1, &_arg2); end

  private

  # If timeoutMS is set for the operation context, checks whether there is
  # enough time left to send the corresponding message to the server
  # (remaining timeout is bigger than minimum round trip time for
  # the server)

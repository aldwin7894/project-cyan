# @note Only available for Ruby versions 2.2.0 and up.
#
# @since 2.6.0
# @api private
#
# pkg:gem/mongo#lib/mongo/auth/stringprep/profiles/sasl.rb:27
module Mongo::Auth::StringPrep::Profiles::SASL; end


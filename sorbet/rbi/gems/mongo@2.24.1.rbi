# This module contains OpenTelemetry tracing functionality for MongoDB operations.
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry.rb:20
module Mongo::Tracing::OpenTelemetry; end

# CommandTracer is responsible for tracing MongoDB server commands using OpenTelemetry.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:23
class Mongo::Tracing::OpenTelemetry::CommandTracer
  include ::Mongo::Monitoring::Event::Secure

  # Initializes a new CommandTracer.
  #
  # @param otel_tracer [ OpenTelemetry::Trace::Tracer ] the OpenTelemetry tracer.
  # @param parent_tracer [ Mongo::Tracing::OpenTelemetry::Tracer ] the parent tracer
  #   for accessing shared context maps.
  # @param query_text_max_length [ Integer ] maximum length for captured query text.
  #   Defaults to 0 (no query text capture).
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:40
  def initialize(otel_tracer, parent_tracer, query_text_max_length: T.unsafe(nil)); end

  # Starts a span for a MongoDB command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  # @param operation_context [ Mongo::Operation::Context ] the operation context.
  # @param connection [ Mongo::Server::Connection ] the connection.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:51
  def start_span(message, operation_context, connection); end

  # Trace a MongoDB command.
  #
  # Creates an OpenTelemetry span for the command, capturing attributes such as
  # command name, database name, collection name, server address, connection IDs,
  # and optionally query text. The span is automatically nested under the current
  # operation span and is finished when the command completes or fails.
  #
  # @param message [ Mongo::Protocol::Message ] the command message to trace.
  # @param _operation_context [ Mongo::Operation::Context ] the context of the operation.
  # @param connection [ Mongo::Server::Connection ] the connection used to send the command.
  #
  # @yield the block representing the command to be traced.
  #
  # @return [ Object ] the result of the command.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:68
  def trace_command(message, _operation_context, connection); end

  private

  # Returns base database and command attributes.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ Hash ] base span attributes.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:163
  def base_attributes(message); end

  # Extracts the collection name from the command message.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ String | nil ] the collection name, or nil if not applicable.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:247
  def collection_name(message); end

  # Extracts the command name from the message.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ String ] the command name.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:265
  def command_name(message); end

  # Returns connection-related attributes.
  #
  # @param connection [ Mongo::Server::Connection ] the connection.
  #
  # @return [ Hash ] connection span attributes.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:179
  def connection_attributes(connection); end

  # Creates a span for a command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  # @param connection [ Mongo::Server::Connection ] the connection.
  #
  # @return [ OpenTelemetry::Trace::Span ] the created span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:112
  def create_command_span(message, connection); end

  # Extracts the cursor ID from getMore commands.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ Integer | nil ] the cursor ID, or nil if not a getMore command.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:290
  def cursor_id(message); end

  # Extracts the database name from the message.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ String ] the database name.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:274
  def database(message); end

  # Handles exceptions that occur during command execution.
  #
  # @param span [ OpenTelemetry::Trace::Span | nil ] the span.
  # @param exception [ Exception ] the exception that occurred.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:135
  def handle_command_exception(span, exception); end

  # Extracts the logical session ID from the command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ BSON::Binary | nil ] the session ID, or nil if not present.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:301
  def lsid(message); end

  # Records error status code if the command failed.
  #
  # @param result [ Object ] the command result.
  # @param span [ OpenTelemetry::Trace::Span ] the current span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:218
  def maybe_trace_error(result, span); end

  # Processes the command result and updates span attributes.
  #
  # @param result [ Object ] the command result.
  # @param cursor_id [ Integer | nil ] the cursor ID.
  # @param context [ OpenTelemetry::Context ] the context.
  # @param span [ OpenTelemetry::Trace::Span ] the current span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:126
  def process_command_result(result, cursor_id, context, span); end

  # Processes cursor context from the command result.
  #
  # @param result [ Object ] the command result.
  # @param _cursor_id [ Integer | nil ] the cursor ID (unused).
  # @param _context [ OpenTelemetry::Context ] the context (unused).
  # @param span [ OpenTelemetry::Trace::Span ] the current span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:208
  def process_cursor_context(result, _cursor_id, _context, span); end

  # Generates a summary string for the query.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ String ] summary in format "command_name db.collection" or "command_name db".
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:234
  def query_summary(message); end

  # Extracts and formats the query text from the command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ String | nil ] JSON representation of the command, truncated if necessary, or nil if disabled.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:331
  def query_text(message); end

  # Checks if query text capture is enabled.
  #
  # @return [ Boolean ] true if query text should be captured.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:281
  def query_text?; end

  # Returns session and transaction attributes.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ Hash ] session span attributes.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:194
  def session_attributes(message); end

  # Determines whether the command must not be traced. Sensitive auth
  # commands carry credentials in their payloads (SCRAM proofs, cleartext
  # passwords, etc.) and the OpenTelemetry spec requires drivers to skip
  # command spans for them. Hello / legacy hello are also skipped to keep
  # handshake traffic out of traces.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ Boolean ] true when no command span should be created.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:99
  def skip_tracing?(message); end

  # Builds span attributes for the command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  # @param connection [ Mongo::Server::Connection ] the connection.
  #
  # @return [ Hash ] OpenTelemetry span attributes following MongoDB semantic conventions.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:151
  def span_attributes(message, connection); end

  # Extracts the transaction number from the command.
  #
  # @param message [ Mongo::Protocol::Message ] the command message.
  #
  # @return [ Integer | nil ] the transaction number, or nil if not present.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:313
  def txn_number(message); end
end

# Ellipsis for truncated query text.
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:324
Mongo::Tracing::OpenTelemetry::CommandTracer::ELLIPSIS = T.let(T.unsafe(nil), String)

# Keys to exclude from query text capture.
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:321
Mongo::Tracing::OpenTelemetry::CommandTracer::EXCLUDED_KEYS = T.let(T.unsafe(nil), Array)

# Commands for which a span MUST NOT be created. The OpenTelemetry spec
# requires drivers to skip command spans for sensitive commands listed in
# the Command Logging and Monitoring spec. We additionally skip hello /
# legacy hello in all forms — these are handshake/heartbeat traffic and
# would only add noise to traces.
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/command_tracer.rb:31
Mongo::Tracing::OpenTelemetry::CommandTracer::HELLO_COMMANDS = T.let(T.unsafe(nil), Array)

# OperationTracer is responsible for tracing MongoDB driver operations using OpenTelemetry.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:23
class Mongo::Tracing::OpenTelemetry::OperationTracer
  extend ::Forwardable

  # Initializes a new OperationTracer.
  #
  # @param otel_tracer [ OpenTelemetry::Trace::Tracer ] the OpenTelemetry tracer.
  # @param parent_tracer [ Mongo::Tracing::OpenTelemetry::Tracer ] the parent tracer
  #   for accessing shared context maps.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:37
  def initialize(otel_tracer, parent_tracer); end

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:26
  def cursor_context_map(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:26
  def parent_context_for(*_arg0, **_arg1, &_arg2); end

  # Trace a MongoDB operation.
  #
  # Creates an OpenTelemetry span for the operation, capturing attributes such as
  # database name, collection name, operation name, and cursor ID. The span is finished
  # automatically when the operation completes or fails.
  #
  # @param operation [ Mongo::Operation ] the MongoDB operation to trace.
  # @param operation_context [ Mongo::Operation::Context ] the context of the operation.
  # @param op_name [ String | nil ] an optional name for the operation. If nil, the
  #   operation class name is used.
  #
  # @yield the block representing the operation to be traced.
  #
  # @return [ Object ] the result of the operation.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:58
  def trace_operation(operation, operation_context, op_name: T.unsafe(nil), &block); end

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:26
  def transaction_context_map(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:26
  def transaction_map_key(*_arg0, **_arg1, &_arg2); end

  private

  # Returns the collection key for a given operation type.
  #
  # @param operation [ Mongo::Operation ] the operation.
  #
  # @return [ Symbol | nil ] the collection key symbol or nil.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:199
  def collection_key_for_operation(operation); end

  # Extracts the collection name from the operation.
  #
  # @param operation [ Mongo::Operation ] the operation.
  #
  # @return [ String | nil ] the collection name, or nil if not applicable.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:171
  def collection_name(operation); end

  # Creates an OpenTelemetry span for the operation.
  #
  # @param operation [ Mongo::Operation ] the operation.
  # @param operation_context [ Mongo::Operation::Context ] the operation context.
  # @param op_name [ String | nil ] optional operation name.
  #
  # @return [ OpenTelemetry::Trace::Span ] the created span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:78
  def create_operation_span(operation, operation_context, op_name); end

  # Executes the operation block within the span context.
  #
  # @param span [ OpenTelemetry::Trace::Span ] the span.
  # @param operation [ Mongo::Operation ] the operation.
  #
  # @yield the block to execute.
  #
  # @return [ Object ] the result of the block.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:96
  def execute_with_span(span, operation); end

  # Extracts collection name from operation spec based on operation type.
  #
  # @param operation [ Mongo::Operation ] the operation.
  #
  # @return [ String | nil ] the collection name, or nil if not found.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:182
  def extract_collection_from_spec(operation); end

  # Handles exception for the span.
  #
  # @param span [ OpenTelemetry::Trace::Span ] the span.
  # @param exception [ Exception ] the exception.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:108
  def handle_span_exception(span, exception); end

  # Returns the operation name from the provided name or operation class.
  #
  # @param operation [ Mongo::Operation ] the operation.
  # @param op_name [ String | nil ] optional operation name.
  #
  # @return [ String ] the operation name in lowercase.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:123
  def operation_name(operation, op_name = T.unsafe(nil)); end

  # Generates the span name for the operation.
  #
  # @param operation [ Mongo::Operation ] the operation.
  # @param op_name [ String | nil ] optional operation name.
  #
  # @return [ String ] span name in format "operation_name db.collection" or "operation_name db".
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:216
  def operation_span_name(operation, op_name = T.unsafe(nil)); end

  # Processes cursor context after operation execution.
  #
  # Updates the cursor context map based on the result. Removes closed cursors
  # and stores context for newly created cursors.
  #
  # @param result [ Object ] the operation result.
  # @param cursor_id [ Integer | nil ] the cursor ID before the operation.
  # @param context [ OpenTelemetry::Context ] the OpenTelemetry context.
  # @param span [ OpenTelemetry::Trace::Span ] the current span.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:153
  def process_cursor_context(result, cursor_id, context, span); end

  # Builds span attributes for the operation.
  #
  # @param operation [ Mongo::Operation ] the operation.
  # @param op_name [ String | nil ] optional operation name.
  #
  # @return [ Hash ] OpenTelemetry span attributes following MongoDB semantic conventions.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/operation_tracer.rb:133
  def span_attributes(operation, op_name); end
end

# OpenTelemetry tracer for MongoDB operations and commands.
# @api private
#
# pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:22
class Mongo::Tracing::OpenTelemetry::Tracer
  # Initializes a new OpenTelemetry tracer.
  #
  # @param enabled [ Boolean | nil ] whether OpenTelemetry is enabled or not.
  #   Defaults to nil, which means it will check the environment variable
  #   OTEL_RUBY_INSTRUMENTATION_MONGODB_ENABLED (values: true/1/yes). If the
  #   environment variable is not set, OpenTelemetry will be disabled by default.
  # @param query_text_max_length [ Integer | nil ] maximum length for captured query text.
  #   Defaults to nil, which means it will check the environment variable
  #   OTEL_RUBY_INSTRUMENTATION_MONGODB_QUERY_TEXT_MAX_LENGTH. If the environment variable is not set,
  #   the query text will not be captured.
  # @param otel_tracer [ OpenTelemetry::Trace::Tracer | nil ] the OpenTelemetry tracer
  #   implementation to use. Defaults to nil, which means it will use the default tracer
  #   from OpenTelemetry's tracer provider.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:42
  def initialize(enabled: T.unsafe(nil), query_text_max_length: T.unsafe(nil), otel_tracer: T.unsafe(nil)); end

  # Returns the cursor context map for tracking cursor-related OpenTelemetry contexts.
  #
  # @return [ Hash ] map of cursor IDs to OpenTelemetry contexts.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:145
  def cursor_context_map; end

  # Generates a unique key for cursor tracking in the context map.
  #
  # @param session [ Mongo::Session ] the session associated with the cursor.
  # @param cursor_id [ Integer ] the cursor ID.
  #
  # @return [ String | nil ] unique key combining session ID and cursor ID, or nil if either is nil.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:155
  def cursor_map_key(session, cursor_id); end

  # Whether OpenTelemetry is enabled or not.
  #
  # @return [Boolean] true if OpenTelemetry is enabled, false otherwise.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:62
  def enabled?; end

  # Finish a transaction span and deactivate its context.
  #
  # @param session [Mongo::Session] The session finishing the transaction.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:123
  def finish_transaction_span(session); end

  # @return [ OpenTelemetry::Trace::Tracer ] the OpenTelemetry tracer implementation
  #   used to create spans for MongoDB operations and commands.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:27
  def otel_tracer; end

  # Determines the parent OpenTelemetry context for an operation.
  #
  # Returns the transaction context if the operation is part of a transaction,
  # otherwise returns nil. Cursor-based context nesting is not currently implemented.
  #
  # @param operation_context [ Mongo::Operation::Context ] the operation context.
  # @param cursor_id [ Integer ] the cursor ID, if applicable.
  #
  # @return [ OpenTelemetry::Context | nil ] parent context or nil.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:170
  def parent_context_for(operation_context, cursor_id); end

  # Start a transaction span and activate its context.
  #
  # @param session [Mongo::Session] The session starting the transaction.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:95
  def start_transaction_span(session); end

  # Trace a MongoDB command.
  #
  # @param message [Mongo::Protocol::Message] The MongoDB command message to trace.
  # @param operation_context [Mongo::Operation::Context] The context of the operation.
  # @param connection [Mongo::Server::Connection] The connection used to send the command
  # @yield The block representing the command to be traced.
  # @return [Object] The result of the command.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:86
  def trace_command(message, operation_context, connection, &block); end

  # Trace a MongoDB operation.
  #
  # @param operation [Mongo::Operation] The MongoDB operation to trace.
  # @param operation_context [Mongo::Operation::Context] The context of the operation.
  # @param op_name [String, nil] An optional name for the operation.
  # @yield The block representing the operation to be traced.
  # @return [Object] The result of the operation.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:73
  def trace_operation(operation, operation_context, op_name: T.unsafe(nil), &block); end

  # Returns the transaction context map for tracking active transaction contexts.
  #
  # @return [ Hash ] map of transaction keys to OpenTelemetry contexts.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:182
  def transaction_context_map; end

  # Generates a unique key for transaction tracking.
  #
  # Returns nil for implicit sessions or sessions not in a transaction.
  #
  # @param session [ Mongo::Session ] the session.
  #
  # @return [ String | nil ] unique key combining session ID and transaction number, or nil.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:207
  def transaction_map_key(session); end

  # Returns the transaction span map for tracking active transaction spans.
  #
  # @return [ Hash ] map of transaction keys to OpenTelemetry spans.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:189
  def transaction_span_map; end

  # Returns the transaction token map for tracking context attachment tokens.
  #
  # @return [ Hash ] map of transaction keys to OpenTelemetry context tokens.
  #
  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:196
  def transaction_token_map; end

  private

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:215
  def check_opentelemetry_loaded; end

  # pkg:gem/mongo#lib/mongo/tracing/open_telemetry/tracer.rb:225
  def initialize_tracer; end
end

# The URI class provides a way for users to parse the MongoDB uri as
# defined in the connection string format spec.
#
# https://www.mongodb.com/docs/manual/reference/connection-string/
#
# @example Use the uri string to make a client connection.
#   uri = Mongo::URI.new('mongodb://localhost:27017')
#   client = Mongo::Client.new(uri.servers, uri.options)
#   client.login(uri.credentials)
#   client[uri.database]
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:30
class Mongo::URI
  include ::Mongo::Loggable
  include ::Mongo::Address::Validator

  # Create the new uri from the provided string.
  #
  # @example Create the new URI.
  #   URI.new('mongodb://localhost:27017')
  #
  # @param [ String ] string The URI to parse.
  # @param [ Hash ] options The options.
  #
  # @option options [ Logger ] :logger A custom logger to use.
  #
  # @raise [ Error::InvalidURI ] If the uri does not match the spec.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:282
  def initialize(string, options = T.unsafe(nil)); end

  # Gets the options hash that needs to be passed to a Mongo::Client on
  # instantiation, so we don't have to merge the credentials and database in
  # at that point - we only have a single point here.
  #
  # @example Get the client options.
  #   uri.client_options
  #
  # @return [ Mongo::Options::Redacted ] The options passed to the Mongo::Client
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:257
  def client_options; end

  # Get the credentials provided in the URI.
  #
  # @example Get the credentials.
  #   uri.credentials
  #
  # @return [ Hash ] The credentials.
  #   * :user [ String ] The user.
  #   * :password [ String ] The provided password.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:307
  def credentials; end

  # Get the database provided in the URI.
  #
  # @example Get the database.
  #   uri.database
  #
  # @return [String] The database.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:319
  def database; end

  # The uri parser object options.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:37
  def options; end

  # The servers specified in the uri.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:47
  def servers; end

  # pkg:gem/mongo#lib/mongo/uri.rb:265
  def srv_records; end

  # Get the uri as a string.
  #
  # @example Get the uri as a string.
  #   uri.to_s
  #
  # @return [ String ] The uri string.
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:329
  def to_s; end

  # Mongo::Options::Redacted of the options specified in the uri.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:42
  def uri_options; end

  private

  # pkg:gem/mongo#lib/mongo/uri.rb:451
  def decode(value); end

  # pkg:gem/mongo#lib/mongo/uri.rb:455
  def encode(value); end

  # pkg:gem/mongo#lib/mongo/uri.rb:398
  def options_mapper; end

  # pkg:gem/mongo#lib/mongo/uri.rb:366
  def parse!(remaining); end

  # pkg:gem/mongo#lib/mongo/uri.rb:438
  def parse_database!(string); end

  # pkg:gem/mongo#lib/mongo/uri.rb:429
  def parse_password!(string); end

  # pkg:gem/mongo#lib/mongo/uri.rb:404
  def parse_uri_options!(string); end

  # pkg:gem/mongo#lib/mongo/uri.rb:420
  def parse_user!(string); end

  # pkg:gem/mongo#lib/mongo/uri.rb:443
  def raise_invalid_error!(details); end

  # pkg:gem/mongo#lib/mongo/uri.rb:447
  def raise_invalid_error_no_fmt!(details); end

  # Reconstruct the URI from its parts. Invalid options are dropped and options
  # are converted to camelCase.
  #
  # @return [ String ] the uri.
  #
  # pkg:gem/mongo#lib/mongo/uri.rb:339
  def reconstruct_uri; end

  # pkg:gem/mongo#lib/mongo/uri.rb:362
  def scheme; end

  # pkg:gem/mongo#lib/mongo/uri.rb:459
  def validate_uri_options!; end

  class << self
    # Get either a URI object or a SRVProtocol URI object.
    #
    # @example Get the uri object.
    #   URI.get(string)
    #
    # @param [ String ] string The URI to parse.
    # @param [ Hash ] opts The options.
    #
    # @option options [ Logger ] :logger A custom logger to use.
    #
    # @return [URI, URI::SRVProtocol] The uri object.
    #
    # @since 2.5.0
    #
    # pkg:gem/mongo#lib/mongo/uri.rb:231
    def get(string, opts = T.unsafe(nil)); end
  end
end

# The character delimiting auth credentials.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:137
Mongo::URI::AUTH_DELIM = T.let(T.unsafe(nil), String)

# Map of URI authentication mechanisms to Ruby driver mechanisms
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:194
Mongo::URI::AUTH_MECH_MAP = T.let(T.unsafe(nil), Hash)

# The character separating a username from the password.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:132
Mongo::URI::AUTH_USER_PWD_DELIM = T.let(T.unsafe(nil), String)

# The character delimiting a database.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:111
Mongo::URI::DATABASE_DELIM = T.let(T.unsafe(nil), String)

# MongoDB URI format specification.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:75
Mongo::URI::FORMAT = T.let(T.unsafe(nil), String)

# MongoDB URI (connection string) documentation url
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:81
Mongo::URI::HELP = T.let(T.unsafe(nil), String)

# The character delimiting hosts.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:101
Mongo::URI::HOST_DELIM = T.let(T.unsafe(nil), String)

# The character separating a host and port.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:106
Mongo::URI::HOST_PORT_DELIM = T.let(T.unsafe(nil), String)

# The character delimiting multiple options.
#
# @since 2.1.0
# @deprecated
#
# pkg:gem/mongo#lib/mongo/uri.rb:122
Mongo::URI::INDIV_URI_OPTS_DELIM = T.let(T.unsafe(nil), String)

# Error details for a missing host.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:173
Mongo::URI::INVALID_HOST = T.let(T.unsafe(nil), String)

# Error details for providing options without a database delimiter.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:168
Mongo::URI::INVALID_OPTS_DELIM = T.let(T.unsafe(nil), String)

# Error details for an invalid options format.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:147
Mongo::URI::INVALID_OPTS_VALUE_DELIM = T.let(T.unsafe(nil), String)

# Error details for an invalid port.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:178
Mongo::URI::INVALID_PORT = T.let(T.unsafe(nil), String)

# Error details for an invalid scheme.
#
# @since 2.1.0
# @deprecated
#
# pkg:gem/mongo#lib/mongo/uri.rb:70
Mongo::URI::INVALID_SCHEME = T.let(T.unsafe(nil), String)

# The mongodb connection string scheme root.
#
# @since 2.5.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:59
Mongo::URI::MONGODB_SCHEME = T.let(T.unsafe(nil), String)

# The mongodb srv protocol connection string scheme root.
#
# @since 2.5.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:64
Mongo::URI::MONGODB_SRV_SCHEME = T.let(T.unsafe(nil), String)

# Performs mapping between URI options and Ruby options.
#
# This class contains:
#
# - The mapping defining how URI options are converted to Ruby options.
# - The mapping from downcased URI option names to canonical-cased URI
#   option names.
# - Methods to perform conversion of URI option values to Ruby option
#   values (the convert_* methods). These generally warn and return nil
#   when input given is invalid.
# - Methods to perform conversion of Ruby option values to standardized
#   MongoClient options (revert_* methods). These assume the input is valid
#   and generally do not perform validation.
#
# URI option names are case insensitive. Ruby options are specified as
# symbols (though in Client options use indifferent access).
#
# @api private
#
# pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:37
class Mongo::URI::OptionsMapper
  include ::Mongo::Loggable

  # Instantiates the options mapper.
  #
  # @option opts [ Logger ] :logger A custom logger to use.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:43
  def initialize(**opts); end

  # Adds an option to the uri options hash.
  #
  #   Acquires a target for the option based on group.
  #   Transforms the value.
  #   Merges the option into the target.
  #
  # @param [ String ] key URI option name.
  # @param [ String ] value The value of the option.
  # @param [ Hash ] uri_options The base option target.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:59
  def add_uri_option(key, value, uri_options); end

  # @return [ Hash ] The options.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:48
  def options; end

  # Converts Ruby options provided to "standardized MongoClient options".
  #
  # @param [ Hash ] opts Ruby options to convert.
  #
  # @return [ Hash ] Standardized MongoClient options.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:117
  def ruby_to_smc(opts); end

  # Converts Ruby options provided to their representation in a URI string.
  #
  # @param [ Hash ] opts Ruby options to convert.
  #
  # @return [ Hash ] URI string hash.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:155
  def ruby_to_string(opts); end

  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:83
  def smc_to_ruby(opts); end

  private

  # Applies URI value transformation by either using the default cast
  # or a transformation appropriate for the given type.
  #
  # @param [ String ] key URI option name.
  # @param [ String ] value The value to be transformed.
  # @param [ Symbol ] type The transform method.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:218
  def apply_transform(key, value, type); end

  # Extract values from the string and put them into an array.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The string to build an array from.
  #
  # @return [ Array<String> ] The array built from the string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:536
  def convert_array(_name, value); end

  # Authentication mechanism transformation.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The authentication mechanism.
  #
  # @return [ Symbol ] The transformed authentication mechanism.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:564
  def convert_auth_mech(_name, value); end

  # Auth mechanism properties extractor.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The auth mechanism properties string.
  #
  # @return [ Hash | nil ] The auth mechanism properties hash.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:604
  def convert_auth_mech_props(_name, value); end

  # Converts +value+ to a boolean.
  #
  # Returns true for 'true', false for 'false', otherwise nil.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | true | false ] value URI option value.
  #
  # @return [ true | false | nil ] Converted value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:325
  def convert_bool(name, value); end

  # Converts +value+ into an integer. Only converts positive integers.
  #
  # If the value is not a valid integer, warns and returns nil.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Integer ] value URI option value.
  #
  # @return [ nil | Integer ] Converted value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:432
  def convert_integer(name, value); end

  # Parses a boolean value and returns its inverse.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | true | false ] value The URI option value.
  #
  # @return [ true | false | nil ] The inverse of the boolean value parsed out, otherwise nil
  #   (and a warning will be logged).
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:396
  def convert_inverse_bool(name, value); end

  # Parses the max staleness value, which must be either "0" or an integer
  # greater or equal to 90.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Integer ] value The max staleness string.
  #
  # @return [ Integer | nil ] The max staleness integer parsed out if it is valid, otherwise nil
  #   (and a warning will be logged).
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:642
  def convert_max_staleness(_name, value); end

  # Ruby's convention is to provide timeouts in seconds, not milliseconds and
  # to use fractions where more precision is necessary. The connection string
  # options are always in MS so we provide an easy conversion type.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Integer | Float ] value The millisecond value.
  #
  # @return [ Float ] The seconds value.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:469
  def convert_ms(name, value); end

  # Read preference mode transformation.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The read mode string value.
  #
  # @return [ Symbol | String ] The read mode.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:688
  def convert_read_mode(_name, value); end

  # Read preference tag set extractor.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The tag set string.
  #
  # @return [ Hash ] The tag set hash.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:764
  def convert_read_set(_name, value); end

  # Read preference tags transformation.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The string representing tag set.
  #
  # @return [ Array<Hash> | nil ] Array with tag set.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:733
  def convert_read_tags(name, value); end

  # Converts the value into a boolean and returns it wrapped in an array.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value URI option value.
  #
  # @return [ Array<true | false> | nil ] The boolean value parsed and wraped
  #   in an array.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:362
  def convert_repeated_bool(name, value); end

  # Server monitoring mode transformation.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The server monitoring mode string value.
  #
  # @return [ Symbol | nil ] The server monitoring mode symbol.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:708
  def convert_server_monitoring_mode(_name, value); end

  # Converts +value+ into a symbol.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Symbol ] value URI option value.
  #
  # @return [ Symbol ] Converted value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:516
  def convert_symbol(_name, value); end

  # Converts +value+ as a write concern.
  #
  # If +value+ is the word "majority", returns the symbol :majority.
  # If +value+ is a number, returns the number as an integer.
  # Otherwise returns the string +value+ unchanged.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Integer ] value URI option value.
  #
  # @return [ Integer | Symbol | String ] Converted value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:778
  def convert_w(_name, value); end

  # Parses the zlib compression level.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String | Integer ] value The zlib compression level string.
  #
  # @return [ Integer | nil ] The compression level value if it is between -1 and 9 (inclusive),
  #   otherwise nil (and a warning will be logged).
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:819
  def convert_zlib_compression_level(_name, value); end

  # Extract values from the string and put them into a nested hash.
  #
  # @param [ String ] name Name of the URI option being processed.
  # @param [ String ] value The string to build a hash from.
  #
  # @return [ Hash ] The hash built from the string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:858
  def hash_extractor(name, value); end

  # Merges a new option into the target.
  #
  # If the option exists at the target destination the merge will
  # be an addition.
  #
  # Specifically required to append an additional tag set
  # to the array of tag sets without overwriting the original.
  #
  # @param [ Hash ] target The destination.
  # @param [ Object ] value The value to be merged.
  # @param [ Symbol ] name The name of the option.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:237
  def merge_uri_option(target, value, name); end

  # Reverts an array.
  #
  # @param [ Array<String> ] value An array of strings.
  #
  # @return [ Array<String> ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:545
  def revert_array(value); end

  # Reverts auth mechanism.
  #
  # @param [ Symbol ] value The auth mechanism.
  #
  # @return [ String ] The auth mechanism as a string.
  #
  # @raise [ ArgumentError ] if its an invalid auth mechanism.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:578
  def revert_auth_mech(value); end

  # Reverts auth mechanism properties.
  #
  # @param [ Hash | nil ] value The auth mech properties.
  #
  # @return [ Hash | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:619
  def revert_auth_mech_props(value); end

  # Reverts a boolean type.
  #
  # @param [ true | false | nil ] value The boolean to revert.
  #
  # @return [ true | false | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:342
  def revert_bool(value); end

  # Reverts an integer.
  #
  # @param [ Integer | nil ] value The integer.
  #
  # @return [ Integer | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:446
  def revert_integer(value); end

  # Reverts and inverts a boolean type.
  #
  # @param [ true | false | nil ] value The boolean to revert and invert.
  #
  # @return [ true | false | nil ] The inverted boolean.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:411
  def revert_inverse_bool(value); end

  # Reverts max staleness.
  #
  # @param [ Integer | nil ] value The max staleness.
  #
  # @return [ Integer | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:669
  def revert_max_staleness(value); end

  # Reverts an ms.
  #
  # @param [ Float ] value The float.
  #
  # @return [ Integer ] The number multiplied by 1000 as an integer.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:497
  def revert_ms(value); end

  # Reverts read mode.
  #
  # @param [ Symbol | String ] value The read mode.
  #
  # @return [ String ] The read mode as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:697
  def revert_read_mode(value); end

  # Reverts read tags.
  #
  # @param [ Array<Hash> | nil ] value The read tags.
  #
  # @return [ Array<Hash> | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:745
  def revert_read_tags(value); end

  # Reverts a repeated boolean type.
  #
  # @param [ Array<true | false> | true | false | nil ] value The repeated boolean to revert.
  #
  # @return [ Array<true | false> | true | false | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:371
  def revert_repeated_bool(value); end

  # Reverts a symbol.
  #
  # @param [ Symbol ] value The symbol.
  #
  # @return [ String ] The passed value as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:525
  def revert_symbol(value); end

  # Reverts write concern.
  #
  # @param [ Integer | Symbol | String ] value The write concern.
  #
  # @return [ Integer | String ] The write concern as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:794
  def revert_w(value); end

  # Reverts zlib compression level
  #
  # @param [ Integer | nil ] value The write concern.
  #
  # @return [ Integer | nil ] The passed value.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:839
  def revert_zlib_compression_level(value); end

  # Stringifies an array.
  #
  # @param [ Array<String> ] value An array of strings.
  #
  # @return [ String ] The array joined by commas.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:554
  def stringify_array(value); end

  # Stringifies auth mechanism.
  #
  # @param [ Symbol ] value The auth mechanism.
  #
  # @return [ String | nil ] The auth mechanism as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:592
  def stringify_auth_mech(value); end

  # Stringifies auth mechanism properties.
  #
  # @param [ Hash | nil ] value The auth mech properties.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:628
  def stringify_auth_mech_props(value); end

  # Stringifies a boolean type.
  #
  # @param [ true | false | nil ] value The boolean.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:351
  def stringify_bool(value); end

  # Stringifies an integer.
  #
  # @param [ Integer | nil ] value The integer.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:455
  def stringify_integer(value); end

  # Inverts and stringifies a boolean.
  #
  # @param [ true | false | nil ] value The boolean.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:420
  def stringify_inverse_bool(value); end

  # Stringifies max staleness.
  #
  # @param [ Integer | nil ] value The max staleness.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:678
  def stringify_max_staleness(value); end

  # Stringifies an ms.
  #
  # @param [ Float ] value The float.
  #
  # @return [ String ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:506
  def stringify_ms(value); end

  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:700
  def stringify_read_mode(value); end

  # Stringifies read tags.
  #
  # @param [ Array<Hash> | nil ] value The read tags.
  #
  # @return [ String | nil ] The joined string of read tags.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:754
  def stringify_read_tags(value); end

  # Stringifies a repeated boolean type.
  #
  # @param [ Array<true | false> | nil ] value The repeated boolean.
  #
  # @return [ Array<true | false> | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:380
  def stringify_repeated_bool(value); end

  # Stringifies server monitoring mode.
  #
  # @param [ Symbol ] value The server monitoring mode.
  #
  # @return [ String ] The server monitoring mode as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:723
  def stringify_server_monitoring_mode(value); end

  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:528
  def stringify_symbol(value); end

  # Stringifies write concern.
  #
  # @param [ Integer | Symbol | String ] value The write concern.
  #
  # @return [ String ] The write concern as a string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:808
  def stringify_w(value); end

  # Stringifies zlib compression level
  #
  # @param [ Integer | nil ] value The write concern.
  #
  # @return [ String | nil ] The string.
  #
  # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:848
  def stringify_zlib_compression_level(value); end

  class << self
    # Simple internal dsl to register a MongoDB URI option in the URI_OPTION_MAP.
    #
    # @param [ String ] uri_key The MongoDB URI option to register.
    # @param [ Symbol ] name The name of the option in the driver.
    # @param [ Hash ] extra Extra options.
    #   * :group [ Symbol ] Nested hash where option will go.
    #   * :type [ Symbol ] Name of function to transform value.
    # @api private
    #
    # pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:205
    def uri_option(uri_key, name, **extra); end
  end
end

# @return [ Hash<String, String> ] Map from lowercased to canonical URI
#   option names.
# @api private
#
# pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:195
Mongo::URI::OptionsMapper::URI_OPTION_CANONICAL_NAMES = T.let(T.unsafe(nil), Hash)

# Hash for storing map of URI option parameters to conversion strategies
# @api private
#
# pkg:gem/mongo#lib/mongo/uri/options_mapper.rb:190
Mongo::URI::OptionsMapper::URI_OPTION_MAP = T.let(T.unsafe(nil), Hash)

# Percent sign that must be encoded in user creds.
#
# @since 2.5.1
#
# pkg:gem/mongo#lib/mongo/uri.rb:91
Mongo::URI::PERCENT_CHAR = T.let(T.unsafe(nil), Regexp)

# Map of URI read preference modes to Ruby driver read preference modes
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:183
Mongo::URI::READ_MODE_MAP = T.let(T.unsafe(nil), Hash)

# Options that are allowed to appear more than once in the uri.
#
# In order to follow the URI options spec requirement that all instances
# of 'tls' and 'ssl' have the same value, we need to keep track of all
# of the values passed in for those options. Assuming they don't conflict,
# they will be condensed to a single value immediately after parsing the URI.
#
# @since 2.1.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:216
Mongo::URI::REPEATABLE_OPTIONS = T.let(T.unsafe(nil), Array)

# The mongodb connection string scheme.
#
# @deprecated Will be removed in 3.0.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:54
Mongo::URI::SCHEME = T.let(T.unsafe(nil), String)

# Scheme delimiter.
#
# @since 2.5.0
#
# pkg:gem/mongo#lib/mongo/uri.rb:142
Mongo::URI::SCHEME_DELIM = T.let(T.unsafe(nil), String)

# Valid values for the serverMonitoringMode URI option.
#
# pkg:gem/mongo#lib/mongo/uri.rb:206
Mongo::URI::SERVER_MONITORING_MODES = T.let(T.unsafe(nil), Array)

# Parser for a URI using the mongodb+srv protocol, which specifies a DNS to query for SRV records.
# The driver will query the DNS server for SRV records on <hostname>.<domainname>,
# prefixed with _mongodb._tcp
# The SRV records can then be used as the seedlist for a Mongo::Client.
# The driver also queries for a TXT record providing default connection string options.
# Only one TXT record is allowed, and only a subset of Mongo::Client options is allowed.
#
# Please refer to the Initial DNS Seedlist Discovery spec for details.
#
# https://github.com/mongodb/specifications/blob/master/source/initial-dns-seedlist-discovery/initial-dns-seedlist-discovery.md
#
# @example Use the uri string to make a client connection.
#   client = Mongo::Client.new('mongodb+srv://test6.test.build.10gen.cc/')
#
# @since 2.5.0
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:34
class Mongo::URI::SRVProtocol < ::Mongo::URI
  # Gets the options hash that needs to be passed to a Mongo::Client on instantiation, so we
  # don't have to merge the txt record options, credentials, and database in at that point -
  # we only have a single point here.
  #
  # @example Get the client options.
  #   uri.client_options
  #
  # @return [ Hash ] The options passed to the Mongo::Client
  #
  # @since 2.5.0
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:47
  def client_options; end

  # The hostname that is specified in the URI and used to look up
  # SRV records.
  #
  # This attribute needs to be defined because SRVProtocol changes
  # #servers to be the result of the lookup rather than the hostname
  # specified in the URI.
  #
  # @return [ String ] The hostname used in SRV lookup.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:68
  def query_hostname; end

  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:35
  def srv_records; end

  # @return [ Srv::Result ] SRV lookup result.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:56
  def srv_result; end

  private

  # Obtains the TXT options of a host.
  #
  # @param [ String ] hostname The hostname whose records should be obtained.
  #
  # @return [ Hash ] The TXT record options (an empty hash if no TXT
  #   records are found).
  #
  # @raise [ Mongo::Error::InvalidTXTRecord ] If more than one TXT record is found.
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:193
  def get_txt_options(hostname); end

  # Parses the credentials from the URI and performs DNS queries to obtain
  # the hosts and TXT options.
  #
  # @param [ String ] remaining The portion of the URI pertaining to the
  #   authentication credentials and the hosts.
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:138
  def parse!(remaining); end

  # Parses the TXT record options into a hash and adds the options to set of all URI options
  # parsed.
  #
  # @param [ String ] string The concatenated TXT options.
  #
  # @return [ Hash ] The parsed TXT options.
  #
  # @raise [ Mongo::Error::InvalidTXTRecord ] If the TXT record does not fit the expected form
  #   or the option specified is not a valid TXT option.
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:211
  def parse_txt_options!(string); end

  # Raises an InvalidURI error.
  #
  # @param [ String ] details A detailed error message.
  #
  # @raise [ Mongo::Error::InvalidURI ]
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:116
  def raise_invalid_error!(details); end

  # Gets the SRV resolver.
  # If domain verification fails or no SRV records are found,
  # an error must not be raised per the spec; instead, a warning is logged.
  #
  # @return [ Mongo::Srv::Resolver ]
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:125
  def resolver; end

  # Gets the MongoDB SRV URI scheme.
  #
  # @return [ String ] The MongoDB SRV URI scheme.
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:107
  def scheme; end

  # Validates the hostname used in an SRV URI.
  #
  # The hostname cannot include a port.
  #
  # The hostname must not begin with a dot, end with a dot, or have
  # consecutive dots. The hostname must have a minimum of 1 component
  #
  # Raises Error::InvalidURI if validation fails.
  #
  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:173
  def validate_srv_hostname(hostname); end

  # pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:224
  def validate_uri_options!; end
end

# @return [ String ] DOT_PARTITION The '.' character used to delineate the parts of a
#   hostname.
#
# @deprecated
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:76
Mongo::URI::SRVProtocol::DOT_PARTITION = T.let(T.unsafe(nil), String)

# @return [ String ] FORMAT The expected SRV URI format.
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:102
Mongo::URI::SRVProtocol::FORMAT = T.let(T.unsafe(nil), String)

# @return [ String ] INVALID_DOMAIN Error message format string indicating that the domain name
#   of the hostname does not fit the expected form.
# @deprecated
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:94
Mongo::URI::SRVProtocol::INVALID_DOMAIN = T.let(T.unsafe(nil), String)

# @return [ String ] INVALID_HOST Error message format string indicating that the hostname in
#   in the URI does not fit the expected form.
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:83
Mongo::URI::SRVProtocol::INVALID_HOST = T.let(T.unsafe(nil), String)

# @return [ String ] INVALID_PORT Error message format string indicating that a port was
#   included with an SRV hostname.
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:88
Mongo::URI::SRVProtocol::INVALID_PORT = T.let(T.unsafe(nil), String)

# @return [ String ] NO_SRV_RECORDS Error message format string indicating that no SRV records
#   were found.
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:99
Mongo::URI::SRVProtocol::NO_SRV_RECORDS = T.let(T.unsafe(nil), String)

# @return [ Array<String> ] VALID_TXT_OPTIONS The valid options for a TXT record to specify.
#
# pkg:gem/mongo#lib/mongo/uri/srv_protocol.rb:79
Mongo::URI::SRVProtocol::VALID_TXT_OPTIONS = T.let(T.unsafe(nil), Array)

# Error details for a non-urlencoded auth database name.

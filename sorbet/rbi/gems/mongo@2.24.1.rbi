  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:40
  def last_round_trip_time; end

  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:42
  def measure; end

  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:40
  def minimum_round_trip_time; end

  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:71
  def update_average_round_trip_time; end

  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:79

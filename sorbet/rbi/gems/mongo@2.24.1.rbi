# Known KMS provider names.
#
# pkg:gem/mongo#lib/mongo/crypt/kms/master_key_document.rb:26
Mongo::Crypt::KMS::MasterKeyDocument::KMS_PROVIDERS = T.let(T.unsafe(nil), Array)

# This module contains helper methods for validating KMS parameters.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/crypt/kms.rb:29
module Mongo::Crypt::KMS::Validations
  # Validate if a KMS parameter is valid.
  #
  # @param [ Symbol ] key The parameter name.
  # @param [ Hash ] opts Hash should contain the parameter under the key.
  # @param [ Boolean ] required Whether the parameter is required or not.
  #   Non-required parameters can be nil.
  #
  # @return [ String | nil ] String parameter value or nil if a
  #   non-required parameter is missing.
  #
  # @raise [ ArgumentError ] If required options are missing or incorrectly
  #   formatted.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms.rb:42
  def validate_param(key, opts, format_hint, required: T.unsafe(nil)); end

  private

  # Validate KMS TLS options.
  #
  # @param [ Hash | nil ] options TLS options to connect to KMS
  #   providers. Keys of the hash should be KSM provider names; values
  #   should be hashes of TLS connection options. The options are equivalent
  #   to TLS connection options of Mongo::Client.
  #
  # @return [ Hash ] Provided TLS options if valid.
  #
  # @raise [ ArgumentError ] If required options are missing or incorrectly
  #   formatted.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms.rb:85
  def validate_tls_options(options); end

  class << self
    # Validate KMS TLS options.
    #
    # @param [ Hash | nil ] options TLS options to connect to KMS
    #   providers. Keys of the hash should be KSM provider names; values
    #   should be hashes of TLS connection options. The options are equivalent
    #   to TLS connection options of Mongo::Client.
    #
    # @return [ Hash ] Provided TLS options if valid.
    #
    # @raise [ ArgumentError ] If required options are missing or incorrectly
    #   formatted.
    #
    # pkg:gem/mongo#lib/mongo/crypt/kms.rb:108
    def validate_tls_options(options); end
  end
end

# Wraps a libmongocrypt mongocrypt_kms_ctx_t object. Contains information
# about making an HTTP request to fetch information about a KMS
# data key.
#
# pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:22
class Mongo::Crypt::KmsContext
  # Create a new KmsContext object.
  #
  # @param [ FFI::Pointer ] kms_ctx A pointer to a mongocrypt_kms_ctx_t
  #   object. This object is managed by the mongocrypt_ctx_t object that
  #   created it; this class is not responsible for de-allocating resources.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:28
  def initialize(kms_ctx); end

  # Return the number of bytes still needed by libmongocrypt to complete
  # the request for information about the AWS data key.
  #
  # @return [ Integer ] The number of bytes needed.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:56
  def bytes_needed; end

  # Return the endpoint at which to make the HTTP request.
  #
  # @return [ String ] The endpoint.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:40
  def endpoint; end

  # Feed a response from the HTTP request to libmongocrypt.
  #
  # @param [ String ] data Data to feed to libmongocrypt.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:63
  def feed(data); end

  # Return the pointer to the underlying mongocrypt_kms_ctx_t object.
  #
  # @return [ FFI::Pointer ] A pointer to a mongocrypt_kms_ctx_t object.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:35
  def kms_ctx_p; end

  # Return the HTTP message to send to fetch information about the relevant
  # KMS data key.
  #
  # @return [ String ] The HTTP message.
  #
  # pkg:gem/mongo#lib/mongo/crypt/kms_context.rb:48
  def message; end
end

# A Context object initialized specifically for the purpose of rewrapping
# data keys (decrypting and re-encrypting using a new KEK).
#
# @api private
#
# pkg:gem/mongo#lib/mongo/crypt/rewrap_many_data_key_context.rb:23
class Mongo::Crypt::RewrapManyDataKeyContext < ::Mongo::Crypt::Context
  # Create a new RewrapManyDataKeyContext object
  #
  # @param [ Mongo::Crypt::Handle ] mongocrypt a Handle that
  #   wraps a mongocrypt_t object used to create a new mongocrypt_ctx_t
  # @param [ Mongo::Crypt::EncryptionIO ] io An object that performs all
  #   driver I/O on behalf of libmongocrypt
  # @param [ Hash ] filter Filter used to find keys to be updated.
  #   alternate names for the new data key.
  # @param [ Mongo::Crypt::KMS::MasterKeyDocument | nil ] master_key_document The optional master
  #   key document that contains master encryption key parameters.
  #
  # pkg:gem/mongo#lib/mongo/crypt/rewrap_many_data_key_context.rb:34
  def initialize(mongocrypt, io, filter, master_key_document); end
end

# Represent result of the rewrap many data key operation.
#
# @api semiprivate
#
# pkg:gem/mongo#lib/mongo/crypt/rewrap_many_data_key_result.rb:22
class Mongo::Crypt::RewrapManyDataKeyResult
  # @param [ BulkWrite::Result | nil ] bulk_write_result The result of the
  #   bulk write operation used to update the key vault collection
  #   with rewrapped data keys.
  #
  # pkg:gem/mongo#lib/mongo/crypt/rewrap_many_data_key_result.rb:30
  def initialize(bulk_write_result); end

  # @return [ BulkWrite::Result ] the result of the bulk write operation
  #   used to update the key vault collection with rewrapped data keys.
  #
  # pkg:gem/mongo#lib/mongo/crypt/rewrap_many_data_key_result.rb:25
  def bulk_write_result; end
end

# A wrapper around mongocrypt_status_t, representing the status of
# a mongocrypt_t handle.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/crypt/status.rb:25
class Mongo::Crypt::Status
  # Create a new Status object
  #
  # @param [ FFI::Pointer | nil ] pointer A pointer to an existing
  #   mongocrypt_status_t object. Defaults to nil.
  #
  # @note When initializing a Status object with a pointer, it is
  # recommended that you use the #self.from_pointer method
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:33
  def initialize(pointer: T.unsafe(nil)); end

  # Return the integer code associated with the status
  #
  # @return [ Integer ] The status code, defaults to 0
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:88
  def code; end

  # Return the label of the status
  #
  # @return [ Symbol ] The status label, either :ok, :error_kms, or :error_client,
  #   defaults to :ok
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:81
  def label; end

  # Return the status message
  #
  # @return [ String ] The status message, defaults to empty string
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:95
  def message; end

  # Checks whether the status is labeled :ok
  #
  # @return [ Boolean ] Whether the status is :ok
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:103
  def ok?; end

  # Raises a Mongo::Error:CryptError corresponding to the
  # information stored in this status
  #
  # Does nothing if self.ok? is true
  #
  # @param kms [ true | false ] Whether the operation was against the KMS.
  #
  # @note If kms parameter is false, the error may still have come from a
  #   KMS. The kms parameter simply forces all errors to be treated as
  #   KMS errors.
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:125
  def raise_crypt_error(kms: T.unsafe(nil)); end

  # Returns the reference to the underlying mongocrypt_status_t
  # object
  #
  # @return [ FFI::Pointer ] Pointer to the underlying mongocrypt_status_t object
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:111
  def ref; end

  # Set a label, code, and message on the Status
  #
  # @param [ Symbol ] label One of :ok, :error_client, or :error_kms
  # @param [ Integer ] code
  # @param [ String ] message
  #
  # @return [ Mongo::Crypt::Status ] returns self
  #
  # pkg:gem/mongo#lib/mongo/crypt/status.rb:63
  def update(label, code, message); end

  class << self
    # Initialize a Status object from an existing pointer to a
    # mongocrypt_status_t object.
    #
    # @param [ FFI::Pointer ] pointer A pointer to an existing
    #   mongocrypt_status_t object
    #
    # @return [ Mongo::Crypt::Status ] A new Status object
    #
    # pkg:gem/mongo#lib/mongo/crypt/status.rb:52
    def from_pointer(pointer); end
  end
end

# This class stores operation timeout and provides corresponding helper methods.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:21
class Mongo::CsotTimeoutHolder
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:22
  def initialize(session: T.unsafe(nil), operation_timeouts: T.unsafe(nil)); end

  # Check whether the operation timeout expired, and raises an appropriate
  # error if yes.
  #
  # @raise [ Error::TimeoutError ]
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:84
  def check_timeout!; end

  # @return [ true | false ] Whether CSOT is enabled for the operation
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:31
  def csot?; end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:28
  def deadline; end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:28
  def operation_timeouts; end

  # @return [ Integer | nil ] Returns the remaining milliseconds of the timeout
  #   set for the operation; if no timeout is set, or the timeout is 0
  #   (means unlimited) returns nil.
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:58
  def remaining_timeout_ms; end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:65
  def remaining_timeout_ms!; end

  # @return [ Float | nil ] Returns the remaining seconds of the timeout
  #   set for the operation; if no timeout is set, or the timeout is 0
  #   (means unlimited) returns nil.
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:44
  def remaining_timeout_sec; end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:50
  def remaining_timeout_sec!; end

  # @return [ true | false ] Returns false if CSOT is not enabled, or if
  #   CSOT is set to 0 (means unlimited), otherwise true.
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:37
  def timeout?; end

  # @return [ true | false ] Whether the timeout for the operation expired.
  #   If no timeout set, this method returns false.
  #
  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:72
  def timeout_expired?; end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:28
  def timeout_sec; end

  private

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:92
  def calculate_deadline(opts = T.unsafe(nil), session = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:110
  def calculate_deadline_from_timeout_ms(operation_timeout_ms); end

  # pkg:gem/mongo#lib/mongo/csot_timeout_holder.rb:103
  def check_no_override_inside_transaction!(opts, session); end
end

# Client-side representation of an iterator over a query result set on
# the server.
#
# +Cursor+ objects are not directly exposed to application code. Rather,
# +Collection::View+ exposes the +Enumerable+ interface to the applications,
# and the enumerator is backed by a +Cursor+ instance.
#
# @example Get an array of 5 users named Emily.
#   users.find({:name => 'Emily'}).limit(5).to_a
#
# @example Call a block on each user doc.
#   users.find.each { |doc| puts doc }
#
# @api private
#
# pkg:gem/mongo#lib/mongo/cursor.rb:32
class Mongo::Cursor
  include ::Enumerable
  include ::Mongo::Retryable
  extend ::Forwardable

  # Creates a +Cursor+ object.
  #
  # @example Instantiate the cursor.
  #   Mongo::Cursor.new(view, response, server)
  #
  # @param [ CollectionView ] view The +CollectionView+ defining the query.
  # @param [ Operation::Result ] result The result of the first execution.
  # @param [ Server ] server The server this cursor is locked to.
  # @param [ Hash ] options The cursor options.
  #
  # @option options [ Operation::Context ] :context The operation context
  #   for this cursor.
  # @option options [ true, false ] :disable_retry Whether to disable
  #   retrying on error when sending getMore operations (deprecated, getMore
  #   operations are no longer retried)
  # @option options [ true, false ] :retry_reads Retry reads (following
  #   the modern mechanism), default is true
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:72
  def initialize(view, result, server, options = T.unsafe(nil)); end

  # Get the batch size.
  #
  # @example Get the batch size.
  #   cursor.batch_size
  #
  # @return [ Integer ] The batch size.
  #
  # @since 2.2.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:269
  def batch_size; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:38
  def client(*_arg0, **_arg1, &_arg2); end

  # Closes this cursor, freeing any associated resources on the client and
  # the server.
  #
  # @return [ nil ] Always nil.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:295
  def close(opts = T.unsafe(nil)); end

  # Is the cursor closed?
  #
  # @example Is the cursor closed?
  #   cursor.closed?
  #
  # @return [ true, false ] If the cursor is closed.
  #
  # @since 2.2.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:286
  def closed?; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:39
  def cluster(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/cursor.rb:37
  def collection(*_arg0, **_arg1, &_arg2); end

  # Get the parsed collection name.
  #
  # @example Get the parsed collection name.
  #   cursor.coll_name
  #
  # @return [ String ] The collection name.
  #
  # @since 2.2.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:333
  def collection_name; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:115
  def connection; end

  # @return [ Operation::Context ] context the context for this cursor
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:51
  def context; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:38
  def database(*_arg0, **_arg1, &_arg2); end

  # Iterate through documents returned from the query.
  #
  # A cursor may be iterated at most once. Incomplete iteration is also
  # allowed. Attempting to iterate the cursor more than once raises
  # InvalidCursorOperation.
  #
  # @example Iterate over the documents in the cursor.
  #   cursor.each do |doc|
  #     ...
  #   end
  #
  # @return [ Enumerator ] The enumerator.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:160
  def each; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:409
  def fully_iterated?; end

  # Execute a getMore command and return the batch of documents
  # obtained from the server.
  #
  # @return [ Array<BSON::Document> ] The batch of documents
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:370
  def get_more; end

  # Get the cursor id.
  #
  # @example Get the cursor id.
  #   cursor.id
  #
  # @note A cursor id of 0 means the cursor was closed on the server.
  #
  # @return [ Integer ] The cursor id.
  #
  # @since 2.2.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:360
  def id; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:112
  def initial_result; end

  # Get a human-readable string representation of +Cursor+.
  #
  # @example Inspect the cursor.
  #   cursor.inspect
  #
  # @return [ String ] A string representation of a +Cursor+ instance.
  #
  # @since 2.0.0
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:142
  def inspect; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:396
  def kill_spec(connection_global_id); end

  # Refreshes the cursor's CSOT context so that the next getMore starts
  # with a fresh timeout deadline. Used by tailable awaitData cursors to
  # implement per-iteration timeout refresh as required by the CSOT spec.
  # Only refreshes if this is a tailable awaitData cursor with an active timeout.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:419
  def refresh_timeout!; end

  # The resume token tracked by the cursor for change stream resuming
  #
  # @return [ BSON::Document | nil ] The cursor resume token.
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:48
  def resume_token; end

  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:109
  def server; end

  # Return one document from the query, if one is available.
  #
  # This method will wait up to max_await_time_ms milliseconds
  # for changes from the server, and if no changes are received
  # it will return nil. If there are no more documents to return
  # from the server, or if we have exhausted the cursor, it will
  # raise a StopIteration exception.
  #
  # @note This method is experimental and subject to change.
  #
  # @return [ BSON::Document | nil ] A document.
  #
  # @raise [ StopIteration ] Raised on the calls after the cursor had been
  #   completely iterated.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:217
  def try_next; end

  # @return [ Collection::View ] view The collection view.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:42
  def view; end

  private

  # pkg:gem/mongo#lib/mongo/cursor.rb:433
  def batch_size_for_get_more; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:451
  def cache_batch_resume_token; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:445
  def cache_resume_token(doc); end

  # Returns the connection that was used to create the cursor back to the
  # corresponding connection pool.
  #
  # In a load balanced topology cursors must use the same connection for the
  # initial and all subsequent operations. Therefore, the connection is not
  # checked into the pool after the initial operation is completed, but
  # only when the cursor is drained.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:583
  def check_in_connection; end

  # Because a context must not have a connection_global_id if the session
  # is already pinned to one, this method checks to see whether or not there's
  # pinned connection_global_id on the session and returns nil if so.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:568
  def connection_global_id_for_context; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:469
  def end_session; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:515
  def execute_operation(op, context: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/cursor.rb:441
  def exhausted?; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:427
  def explicitly_closed?; end

  # Returns a newly instantiated operation context based on the
  # default values from the view.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:557
  def fresh_context(opts = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/cursor.rb:455
  def get_more_operation; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:503
  def limit; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:473
  def limited?; end

  # Considers the timeout mode and will either return the cursor's
  # context directly, or will return a new (refreshed) context.
  #
  # @return [ Operation::Context ] the (possibly-refreshed) context.
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:528
  def possibly_refreshed_context; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:477
  def process(result); end

  # pkg:gem/mongo#lib/mongo/cursor.rb:507
  def register; end

  # Sets @cursor_id from the operation result.
  #
  # In the operation result cursor id can be represented either as Integer
  # value or as BSON::Int64. This method ensures that the instance variable
  # is always of type Integer.
  #
  # @param [ Operation::Result ] result The result of the operation.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cursor.rb:547
  def set_cursor_id(result); end

  # pkg:gem/mongo#lib/mongo/cursor.rb:511
  def unregister; end

  # pkg:gem/mongo#lib/mongo/cursor.rb:499
  def use_limit?; end

  class << self
    # Finalize the cursor for garbage collection. Schedules this cursor to be included
    # in a killCursors operation executed by the Cluster's CursorReaper.
    #
    # @param [ Cursor::KillSpec ] kill_spec The KillCursor operation specification.
    # @param [ Mongo::Cluster ] cluster The cluster associated with this cursor and its server.
    #
    # @return [ Proc ] The Finalizer.
    #
    # @api private
    #
    # pkg:gem/mongo#lib/mongo/cursor.rb:126
    def finalize(kill_spec, cluster); end
  end
end

# This class contains the operation specification for KillCursors.
#
# Its purpose is to ensure we don't misspell attribute names accidentally.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:24
class Mongo::Cursor::KillSpec
  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:25
  def initialize(cursor_id:, coll_name:, db_name:, connection_global_id:, server_address:, session:, connection: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:51
  def ==(other); end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def coll_name; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def connection; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def connection_global_id; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def cursor_id; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def db_name; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:60
  def eql?(other); end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:64
  def hash; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def server_address; end

  # pkg:gem/mongo#lib/mongo/cursor/kill_spec.rb:43
  def session; end
end

# This module is used by cursor-implementing classes to indicate that
# the only cursors they generate are non-tailable, and iterable.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/cursor/nontailable.rb:9
module Mongo::Cursor::NonTailable
  # These views are always non-tailable.
  #
  # @return [ nil ] indicating a non-tailable cursor.
  #
  # pkg:gem/mongo#lib/mongo/cursor/nontailable.rb:13
  def cursor_type; end

  # These views apply timeouts to each iteration of a cursor, as
  # opposed to the entire lifetime of the cursor.
  #
  # @return [ :iterable ] indicating a cursor with a timeout mode of
  #   "iterable".
  #
  # pkg:gem/mongo#lib/mongo/cursor/nontailable.rb:22
  def timeout_mode; end
end

# A shared concern implementing settings and configuration for entities that
# "host" (or spawn) cursors.
#
# The class or module that includes this concern must implement:
#   * timeout_ms -- this must return either the operation level timeout_ms
#       (if set) or an inherited timeout_ms from a hierarchically higher
#       level (if any).
#
# pkg:gem/mongo#lib/mongo/cursor_host.rb:11
module Mongo::CursorHost
  # Returns the cursor associated with this view, if any.
  #
  # @return [ nil | Cursor ] The cursor, if any.
  #
  # @api private
  #

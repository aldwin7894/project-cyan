# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/server/monitor.rb:36
Mongo::Server::Monitor::DEFAULT_HEARTBEAT_INTERVAL = T.let(T.unsafe(nil), Integer)

# The minimum time between forced server scans. Is
# minHeartbeatFrequencyMS in the SDAM spec.
#
# @since 2.0.0
#
# pkg:gem/mongo#lib/mongo/server/monitor.rb:42
Mongo::Server::Monitor::MIN_SCAN_INTERVAL = T.let(T.unsafe(nil), Float)

# The weighting factor (alpha) for calculating the average moving round trip time.
#
# @since 2.0.0
# @deprecated Will be removed in version 3.0.
#
# pkg:gem/mongo#lib/mongo/server/monitor.rb:48
Mongo::Server::Monitor::RTT_WEIGHT_FACTOR = T.let(T.unsafe(nil), Float)

# This class encapsulates connections during handshake and authentication.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/server/pending_connection.rb:22
class Mongo::Server::PendingConnection < ::Mongo::Server::ConnectionBase
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:25
  def initialize(socket, server, monitoring, options = T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:38
  def handshake_and_authenticate!; end

  # @return [ Integer ] The ID for the connection. This is the same ID
  #   as that of the regular Connection object for which this
  #   PendingConnection instance was created.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:36
  def id; end

  private

  # @param [ String | nil ] speculative_auth_client_nonce The client
  #   nonce used in speculative auth on this connection that
  #   produced the specified speculative auth result.
  # @param [ Symbol | nil ] speculative_auth_mech Auth mechanism used
  #   for speculative auth, if speculative auth succeeded. If speculative
  #   auth was not performed or it failed, this must be nil.
  # @param [ BSON::Document | nil ] speculative_auth_result The
  #   value of speculativeAuthenticate field of hello response of
  #   the handshake on this connection.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:199
  def authenticate!(speculative_auth_client_nonce: T.unsafe(nil), speculative_auth_mech: T.unsafe(nil), speculative_auth_result: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:293
  def default_mechanism; end

  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:224
  def ensure_connected; end

  # Sends the hello command to the server, then receive and deserialize
  # the response.
  #
  # This method is extracted to be mocked in the tests.
  #
  # @param [ Protocol::Message ] Command that should be sent to a server
  #   for handshake purposes.
  #
  # @return [ Mongo::Protocol::Reply ] Deserialized server response.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:126
  def get_handshake_response(hello_command); end

  # @param [ BSON::Document | nil ] speculative_auth_doc The document to
  #   provide in speculativeAuthenticate field of handshake command.
  #
  # @return [ BSON::Document ] The document of the handshake response for
  #   this particular connection.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:140
  def handshake!(speculative_auth_doc: T.unsafe(nil)); end

  # This is a separate method to keep the nesting level down.
  #
  # @return [ Server::Description ] The server description calculated from
  #   the handshake response for this particular connection.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:232
  def post_handshake(response, average_rtt, _minimum_rtt); end

  # The user as going to be used for authentication. This user has the
  # auth mechanism set and, if necessary, auth source.
  #
  # @param [ Symbol | nil ] speculative_auth_mech Auth mechanism used
  #   for speculative auth, if speculative auth succeeded. If speculative
  #   auth was not performed or it failed, this must be nil.
  #
  # @return [ Auth::User ] The resolved user.
  #
  # pkg:gem/mongo#lib/mongo/server/pending_connection.rb:266
  def resolved_user(speculative_auth_mech: T.unsafe(nil)); end
end

# A monitor utilizing server-pushed hello requests.
#
# When a Monitor handshakes with a 4.4+ server, it creates an instance
# of PushMonitor. PushMonitor subsequently executes server-pushed hello
# (i.e. awaited & exhausted hello) to receive topology changes from the
# server as quickly as possible. The Monitor still monitors the server
# for round-trip time calculations and to perform immediate checks as
# requested by the application.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/server/push_monitor.rb:29
class Mongo::Server::PushMonitor
  include ::Mongo::Loggable
  include ::Mongo::BackgroundThread
  extend ::Forwardable

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:33
  def initialize(monitor, topology_version, monitoring, **options); end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:131
  def check; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:91
  def do_work; end

  # @return [ Monitor ] The monitor to which this push monitor is attached.
  #
  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:48
  def monitor; end

  # @return [ Monitoring ] monitoring The monitoring.
  #
  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:54
  def monitoring; end

  # @return [ Hash ] Push monitor options.
  #
  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:57
  def options; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:176
  def read_response; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:60
  def server(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:62
  def start!; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:68
  def stop!; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:192
  def to_s; end

  # @return [ TopologyVersion ] Most recently received topology version.
  #
  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:51
  def topology_version; end

  # pkg:gem/mongo#lib/mongo/server/push_monitor.rb:165
  def write_check_command; end
end

# @api private
#
# pkg:gem/mongo#lib/mongo/server/push_monitor/connection.rb:21
class Mongo::Server::PushMonitor::Connection < ::Mongo::Server::Monitor::Connection
  # pkg:gem/mongo#lib/mongo/server/push_monitor/connection.rb:22
  def socket_timeout; end
end

# @api private
#
# pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:20
class Mongo::Server::RoundTripTimeCalculator
  # pkg:gem/mongo#lib/mongo/server/round_trip_time_calculator.rb:32

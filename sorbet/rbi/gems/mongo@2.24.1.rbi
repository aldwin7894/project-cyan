# Context for operations.
#
# Holds various objects needed to make decisions about operation execution
# in a single container, and provides facade methods for the contained
# objects.
#
# The context contains parameters for operations, and as such while an
# operation is being prepared nothing in the context should change.
# When the result of the operation is being processed, the data
# returned by the context may change (for example, because a transaction
# is aborted), but at that point the operation should no longer read
# anything from the context. Because context data may change during
# operation execution, context objects should not be reused for multiple
# operations.
#
# @api private
#
# pkg:gem/mongo#lib/mongo/operation/context.rb:35
class Mongo::Operation::Context < ::Mongo::CsotTimeoutHolder
  # pkg:gem/mongo#lib/mongo/operation/context.rb:36
  def initialize(client: T.unsafe(nil), session: T.unsafe(nil), connection_global_id: T.unsafe(nil), operation_timeouts: T.unsafe(nil), view: T.unsafe(nil), options: T.unsafe(nil)); end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:97
  def aborting_transaction?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:109
  def any_retry_writes?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:63
  def client; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:93
  def committing_transaction?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:81
  def connection_global_id; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:156
  def decrypt(cmd); end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:152
  def decrypt?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:148
  def encrypt(db_name, cmd); end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:144
  def encrypt?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:160
  def encrypter; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:85
  def in_transaction?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:168
  def inspect; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:105
  def legacy_retry_writes?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:101
  def modern_retry_writes?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:63
  def options; end

  # Whether every retry so far has been due to overload only.
  #
  # pkg:gem/mongo#lib/mongo/operation/context.rb:127
  def overload_only_retry?; end

  # Returns a new Operation::Context with the deadline refreshed
  # and relative to the current moment.
  #
  # @return [ Operation::Context ] the refreshed context
  #
  # pkg:gem/mongo#lib/mongo/operation/context.rb:69
  def refresh(connection_global_id: T.unsafe(nil), timeout_ms: T.unsafe(nil), view: T.unsafe(nil)); end

  # Whether the operation is a retry (true) or an initial attempt (false).
  #
  # pkg:gem/mongo#lib/mongo/operation/context.rb:122
  def retry?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:113
  def server_api; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:63
  def session; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:89
  def starting_transaction?; end

  # pkg:gem/mongo#lib/mongo/operation/context.rb:63
  def view; end

  # Returns a new context with the parameters changed as per the
  # provided arguments.
  #
  # @option opts [ true|false ] :is_retry Whether the operation is a retry
  #   or a first attempt.
  #
  # pkg:gem/mongo#lib/mongo/operation/context.rb:136
  def with(**opts); end
end


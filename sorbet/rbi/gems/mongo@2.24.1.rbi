# A manager that sends kill cursors operations at regular intervals to close
# cursors that have been garbage collected without being exhausted.
#
# @api private
#
# @since 2.3.0
#
# pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:25
class Mongo::Cluster::CursorReaper
  include ::Mongo::Retryable

  # Create a cursor reaper.
  #
  # @param [ Cluster ] cluster The cluster.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:39
  def initialize(cluster); end

  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:47
  def cluster; end

  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:203
  def execute; end

  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:204
  def flush; end

  # Execute all pending kill cursors operations.
  #
  # @example Execute pending kill cursors operations.
  #   cursor_reaper.kill_cursors
  #
  # @api private
  #
  # @since 2.3.0
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:126
  def kill_cursors; end

  # Read and decode scheduled kill cursors operations.
  #
  # This method mutates instance variables without locking, so it is not
  # thread safe. Generally, it should not be called itself, this is a helper
  # for `kill_cursor` method.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:103
  def read_scheduled_kill_specs; end

  # Register a cursor id as active.
  #
  # @example Register a cursor as active.
  #   cursor_reaper.register_cursor(id)
  #
  # @param [ Integer ] id The id of the cursor to register as active.
  #
  # @api private
  #
  # @since 2.3.0
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:68
  def register_cursor(id); end

  # Schedule a kill cursors operation to be eventually executed.
  #
  # @param [ Cursor::KillSpec ] kill_spec The kill specification.
  #
  # @api private
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:54
  def schedule_kill_cursor(kill_spec); end

  # Unregister a cursor id, indicating that it's no longer active.
  #
  # @example Unregister a cursor.
  #   cursor_reaper.unregister_cursor(id)
  #
  # @param [ Integer ] id The id of the cursor to unregister.
  #
  # @api private
  #
  # @since 2.3.0
  #
  # pkg:gem/mongo#lib/mongo/cluster/reapers/cursor_reaper.rb:87
  def unregister_cursor(id); end
end


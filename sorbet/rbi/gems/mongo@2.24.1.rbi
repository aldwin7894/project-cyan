# pkg:gem/mongo#lib/mongo/protocol/get_more.rb:111
Mongo::Protocol::GetMore::Upconverter::GET_MORE = T.let(T.unsafe(nil), String)

# MongoDB Wire protocol KillCursors message.
#
# This is a client request message that is sent to the server in order
# to kill a number of cursors.
#
# @api semipublic
#
# pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:25
class Mongo::Protocol::KillCursors < ::Mongo::Protocol::Message
  # Creates a new KillCursors message
  #
  # @example Kill the cursor on the server with id 1.
  #   KillCursors.new([1])
  #
  # @param [ Mongo::Database ] collection The collection.
  # @param [ Mongo::Database ] database The database.
  # @param [ Array<Fixnum> ] cursor_ids The cursor ids to kill.
  #
  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:34
  def initialize(collection, database, cursor_ids); end

  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:78
  def cursor_ids; end

  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:74
  def id_count; end

  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:124
  def op_code; end

  # Return the event payload for monitoring.
  #
  # @example Return the event payload.
  #   message.payload
  #
  # @return [ BSON::Document ] The event payload.
  #
  # @since 2.1.0
  #
  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:50
  def payload; end

  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:70
  def zero; end

  protected

  # pkg:gem/mongo#lib/mongo/protocol/kill_cursors.rb:61
  def upconverter; end
end


  # @return [ Array<Hash, BSON::Document> ] requests The requests.
  #
  # pkg:gem/mongo#lib/mongo/bulk_write.rb:34
  def requests; end

  # Get the write concern for the bulk write.
  #
  # @api private
  #
  # @example Get the write concern.
  #   bulk_write.write_concern
  #

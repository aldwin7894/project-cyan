  # pkg:gem/mongo#lib/mongo/collection/queryable_encryption.rb:62
  def maybe_drop_emm_collections(encrypted_fields, client, session); end

  private

  # Creating encrypted collections is only supported on 7.0.0 and later
  # (wire version 21+).

  # Run Firefox in headless mode.
  #
  # @example Enable headless mode
  #   options = Selenium::WebDriver::Firefox::Options.new
  #   options.headless!
  #
  # pkg:gem/selenium-webdriver#lib/selenium/webdriver/firefox/options.rb:110

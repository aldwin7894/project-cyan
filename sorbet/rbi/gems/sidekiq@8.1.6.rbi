  #       cursor: cursor,
  #       batch_size: 100
  #     )
  #   end
  #
  #   def each_iteration(batch_of_comments, product_id)
  #     comment_ids = batch_of_comments.map(&:id)
  #     CommentService.call(comment_ids: comment_ids)
  #   end

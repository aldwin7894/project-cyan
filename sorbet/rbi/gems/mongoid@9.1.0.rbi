  # @raise [ Errors::DocumentNotFound ] If no document found.
  #
  # @return [ Document ] A matching document.
  #
  # pkg:gem/mongoid#lib/mongoid/findable.rb:239
  def find_by!(attrs = T.unsafe(nil)); end


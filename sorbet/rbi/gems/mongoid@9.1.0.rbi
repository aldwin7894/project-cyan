# pkg:gem/mongoid#lib/mongoid/attributes/readonly.rb:45
module Mongoid::Attributes::Readonly::ClassMethods
  # Defines an attribute as readonly. This will ensure that the value for
  # the attribute is only set when the document is new or we are
  # creating. In other cases, the field write will be ignored with the
  # exception of #remove_attribute and #update_attribute, where an error
  # will get raised.
  #
  # @example Flag fields as readonly.
  #   class Band
  #     include Mongoid::Document
  #     field :name, type: String
  #     field :genre, type: String
  #     attr_readonly :name, :genre
  #   end
  #
  # @param [ Symbol... ] *names The names of the fields.
  # @note When a parent class contains readonly attributes and is then
  # inherited by a child class, the child class will inherit the
  # parent's readonly attributes at the time of its creation.
  # Updating the parent does not propagate down to child classes after wards.
  #
  # pkg:gem/mongoid#lib/mongoid/attributes/readonly.rb:65
  def attr_readonly(*names); end
end

# Adds type-casting behavior to Mongoid::Boolean class.
#
# pkg:gem/mongoid#lib/mongoid/extensions/boolean.rb:5
class Mongoid::Boolean
  extend ::Mongoid::Criteria::Queryable::Extensions::Boolean::ClassMethods

  class << self
    # pkg:gem/mongoid#lib/mongoid/extensions/boolean.rb:23
    def demongoize(object); end

    # Turn the object from the ruby type we deal with to a Mongo friendly
    # type.
    #
    # @example Mongoize the object.
    #   Boolean.mongoize("123.11")
    #
    # @return [ true | false | nil ] The object mongoized or nil.
    #
    # pkg:gem/mongoid#lib/mongoid/extensions/boolean.rb:14
    def mongoize(object); end
  end
end

# Encapsulates behavior around caching.
#
# pkg:gem/mongoid#lib/mongoid/cacheable.rb:5
module Mongoid::Cacheable
  extend ::ActiveSupport::Concern

  # Print out the cache key. This will append different values on the
  # plural model name.
  #
  # If new_record? - will append /new
  # Non-nil cache_version? - append /id
  # Non-nil updated_at - append /id-updated_at.to_formatted_s(cache_timestamp_format)
  # Otherwise - append /id
  #
  # This is usually called inside a cache() block
  #
  # @example Returns the cache key
  #   document.cache_key
  #
  # @return [ String ] the generated cache key
  #
  # pkg:gem/mongoid#lib/mongoid/cacheable.rb:27
  def cache_key; end

  # Return the cache version for this model. By default, it returns the updated_at
  # field (if present) formatted as a string, or nil if the model has no
  # updated_at field. Models with different needs may override this method to
  # suit their desired behavior.
  #
  # @return [ String | nil ] the cache version value
  #
  # TODO: we can test this by using a MemoryStore, putting something in
  # it, then updating the timestamp on the record and trying to read the
  # value from the memory store. It shouldn't find it, because the version
  # has changed.
  #
  # pkg:gem/mongoid#lib/mongoid/cacheable.rb:46
  def cache_version; end
end

# Defines behavior for dirty tracking.
#
# pkg:gem/mongoid#lib/mongoid/changeable.rb:5

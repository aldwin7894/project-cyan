  # @example Get the in memory docs.
  #   enumerable.in_memory
  #
  # @return [ Array<Document> ] The in memory docs.
  #
  # pkg:gem/mongoid#lib/mongoid/association/referenced/has_many/enumerable.rb:307
  def in_memory; end


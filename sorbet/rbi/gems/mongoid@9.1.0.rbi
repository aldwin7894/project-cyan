  #   map_reduce.time
  #
  # @return [ Float ] The time in milliseconds.
  #
  # pkg:gem/mongoid#lib/mongoid/contextual/map_reduce.rb:192
  def time; end

  private

  # pkg:gem/mongoid#lib/mongoid/contextual/map_reduce.rb:227
  def _session; end

  # pkg:gem/mongoid#lib/mongoid/contextual/map_reduce.rb:223
  def validate_out!; end
end

